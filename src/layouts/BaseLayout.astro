---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
  description?: string;
  footerVisible?: boolean;
  footerVersion?: string;
}

const {
  title = "SAGA — Российские решения самообслуживания",
  description = "АО «САГА Технологии» — банкоматы, кассы самообслуживания и системы управления очередью.",
  footerVisible = false,
  footerVersion = "0.142"
} = Astro.props;

const favicon = `${import.meta.env.BASE_URL.replace(/\/+$/, "")}/assets/logos/saga_logo_black.svg`;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f1115" />
    <link rel="icon" href={favicon} type="image/svg+xml" />
  </head>
  <body>
    <slot />
    <SiteFooter isVisible={footerVisible} version={footerVersion} />
  </body>
</html>
