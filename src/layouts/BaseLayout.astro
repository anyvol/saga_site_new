---
import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
  description?: string;
  footerVisible?: boolean;
  footerVersion?: string;
  canonicalPath?: string;
}

const {
  title = "SAGA — Российские решения самообслуживания",
  description = "АО «САГА Технологии» — банкоматы, кассы самообслуживания и системы управления очередью.",
  footerVisible = false,
  footerVersion = "0.5",
  canonicalPath = Astro.url.pathname
} = Astro.props;

const baseUrl = new URL(import.meta.env.BASE_URL, Astro.site ?? Astro.url);
const canonicalUrl = new URL(canonicalPath, baseUrl).toString();
const favicon = `${import.meta.env.BASE_URL.replace(/\/+$/, "")}/assets/logos/saga_logo_black.svg`;
const withBase = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/+$/, "")}/${path.replace(/^\/+/, "")}`;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#0f1115" />
    <link rel="icon" href={favicon} type="image/svg+xml" />
  </head>
  <body>
    <slot />
    <div class="mobile-sticky-cta" aria-label="Быстрые действия">
      <a
        href="tel:+78002222197"
        class="btn btn-primary"
        data-track-event="mobile_call"
      >
        Позвонить
      </a>
      <a
        href={withBase("/contacts")}
        class="btn btn-secondary"
        data-track-event="mobile_lead"
      >
        Оставить заявку
      </a>
    </div>
    <SiteFooter isVisible={footerVisible} version={footerVersion} />
    <script is:inline>
      // #region agent log
      const agentDebugLog = (payload) => {
        const body = JSON.stringify({
          sessionId: "5be6ec",
          runId: "initial-debug",
          ...payload,
          timestamp: Date.now(),
        });
        fetch("http://127.0.0.1:7461/ingest/d1e0618f-7818-42c4-93f3-82f1b4d0e539", {
          method: "POST",
          headers: { "Content-Type": "application/json", "X-Debug-Session-Id": "5be6ec" },
          body,
        }).catch(() => {});
        if (navigator.sendBeacon) {
          navigator.sendBeacon("http://127.0.0.1:7461/ingest/d1e0618f-7818-42c4-93f3-82f1b4d0e539", body);
        }
      };
      // #endregion
      window.dataLayer = window.dataLayer || [];
      window.sagaTrack = (eventName, payload = {}) => {
        window.dataLayer.push({
          event: eventName,
          ...payload,
          page: window.location.pathname,
          ts: Date.now(),
        });
      };

      document.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target : null;
        const trackNode = target?.closest("[data-track-event]");
        if (!trackNode) return;
        const eventName = trackNode.getAttribute("data-track-event");
        if (!eventName) return;
        const label = trackNode.textContent?.trim() || "";
        window.sagaTrack(eventName, { label });
      });

      const initStickyCtaVisibility = () => {
        const stickyCta = document.querySelector(".mobile-sticky-cta");
        const footer = document.getElementById("site-footer");
        // #region agent log
        const slotFirstElement = document.body.firstElementChild;
        agentDebugLog({
          hypothesisId: "H1",
          location: "BaseLayout.astro:script:slotMount",
          message: "Layout slot mount snapshot",
          data: {
            path: window.location.pathname,
            bodyChildCount: document.body.childElementCount,
            firstTag: slotFirstElement?.tagName ?? null,
            hasMain: !!document.querySelector("main"),
            mainClass: document.querySelector("main")?.className ?? null,
          },
        });
        // #endregion
        // #region agent log
        const snapShell = document.querySelector(".snap-shell");
        const firstReveal = document.querySelector(".reveal");
        const firstRevealOpacity = firstReveal ? getComputedStyle(firstReveal).opacity : null;
        agentDebugLog({
          hypothesisId: "H4",
          location: "BaseLayout.astro:script:initStickyCtaVisibility",
          message: "Layout runtime visibility snapshot",
          data: {
            path: window.location.pathname,
            hasSnapShell: !!snapShell,
            snapShellHeight: snapShell ? getComputedStyle(snapShell).height : null,
            snapShellOverflowY: snapShell ? getComputedStyle(snapShell).overflowY : null,
            hasFirstReveal: !!firstReveal,
            firstRevealOpacity,
            hasStickyCta: !!stickyCta,
            hasFooter: !!footer,
          },
        });
        // #endregion
        if (!stickyCta || !footer) return;

        const updateStickyVisibility = (isFooterVisible) => {
          const isMobile = window.innerWidth <= 860;
          stickyCta.classList.toggle("is-hidden", isMobile && isFooterVisible);
        };

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => updateStickyVisibility(entry.isIntersecting));
          },
          { threshold: 0.01 }
        );

        observer.observe(footer);
        window.addEventListener("resize", () => {
          const footerVisible = footer.getBoundingClientRect().top < window.innerHeight;
          updateStickyVisibility(footerVisible);
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initStickyCtaVisibility, { once: true });
      } else {
        initStickyCtaVisibility();
      }
    </script>
  </body>
</html>
