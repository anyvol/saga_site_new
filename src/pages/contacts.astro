---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";

const base = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${base.replace(/\/+$/, "")}/${path.replace(/^\/+/, "")}`;

const contactIcons = [
  {
    label: "Телефон",
    href: "tel:+78002222197",
    icon: withBase("/assets/logos/телефон-logo.png"),
  },
  {
    label: "Почта",
    href: "mailto:info@saga-tech.ru",
    icon: withBase("/assets/logos/почта_logo.png"),
  },
  {
    label: "Telegram",
    href: "https://t.me/SAGACorporation",
    icon: withBase("/assets/logos/tg_logo.png"),
  },
  {
    label: "MAX",
    href: "https://max.ru/id7718589473biz",
    icon: withBase("/assets/logos/Max_logo_2025.png"),
  },
  {
    label: "VK",
    href: "https://vk.com/sagatech",
    icon: withBase("/assets/logos/VK Logo.png"),
  },
];

const productLines = [
  { value: "atm", label: "Банкоматы" },
  { value: "qms", label: "СУО" },
  { value: "ssc", label: "Кассы самообслуживания" },
  { value: "adm", label: "ADM" },
  { value: "info", label: "Инфокиоски" },
  { value: "charging", label: "Зарядные станции" },
];
---

<BaseLayout
  title="Контакты — САГА Технологии"
  description="Связаться с АО «САГА Технологии»: телефоны, почта, Telegram, VK."
  footerVisible={true}
>
  <InnerPageHeader />

  <main class="snap-shell">
    <section class="screen panel-screen contact-screen" id="contacts">
      <div class="container contact-layout">
        <div class="section-copy reveal">
          <div class="eyebrow">Контакты</div>
        </div>

        <div class="contact-card reveal reveal-delay-1">
          <div class="contact-group">
            <div class="contact-kicker">Телефоны</div>
            <a href="tel:+78002222197" class="contact-link">8 800 222-21-97</a>
            <a href="tel:+74959871121" class="contact-link">7 495 987-11-21</a>
          </div>

          <div class="contact-group">
            <div class="contact-kicker">Почта</div>
            <a href="mailto:info@saga-tech.ru" class="contact-link">info@saga-tech.ru</a>
            <div class="contact-kicker">Для прессы</div>
            <a href="mailto:press@sagacorporation.com" class="contact-link">
              press@sagacorporation.com
            </a>
          </div>

          <div class="contact-group">
            <div class="contact-kicker">Адрес</div>
            <div class="contact-text">111622, г. Москва, ул. Большая Косинская, д. 27, строение 16, эт. 5, помещение 508А</div>
            <div class="contact-text">Москва, ул. Уральская, д. 21</div>
          </div>

          <div class="contact-icons">
            {contactIcons.map((item) => (
              <a
                href={item.href}
                class="contact-icon"
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noopener" : undefined}
                aria-label={item.label}
              >
                <img src={item.icon} alt="" loading="lazy" />
              </a>
            ))}
          </div>
        </div>

        <div class="lead-forms-grid">
          <article class="contact-card reveal reveal-delay-2">
            <div class="contact-kicker">Обсудить проект</div>
            <form class="lead-form" data-lead-form="project">
              <label>
                Имя
                <input name="name" type="text" required />
              </label>
              <label>
                Телефон или email
                <input name="contact" type="text" required />
              </label>
              <label>
                Отрасль
                <select name="industry" required>
                  <option value="">Выберите отрасль</option>
                  <option value="bank">Банк</option>
                  <option value="retail">Ритейл</option>
                  <option value="gov">Госсектор</option>
                  <option value="infra">Инфраструктура</option>
                </select>
              </label>
              <label>
                Тип оборудования
                <select name="line" required>
                  <option value="">Выберите линейку</option>
                  {productLines.map((line) => (
                    <option value={line.value}>{line.label}</option>
                  ))}
                </select>
              </label>
              <label>
                Планируемый объем
                <input name="volume" type="text" placeholder="Например: 20 устройств" />
              </label>
              <label>
                Комментарий
                <textarea name="comment" rows={3}></textarea>
              </label>
              <button type="submit" class="btn btn-primary" data-track-event="lead_form_project_submit">
                Отправить запрос
              </button>
            </form>
          </article>

          <article class="contact-card reveal reveal-delay-3">
            <div class="contact-kicker">Быстрый запрос КП</div>
            <form class="lead-form" data-lead-form="quote">
              <label>
                Компания
                <input name="company" type="text" required />
              </label>
              <label>
                Контактное лицо
                <input name="name" type="text" required />
              </label>
              <label>
                Линейка продуктов
                <select name="line" required>
                  <option value="">Выберите линейку</option>
                  {productLines.map((line) => (
                    <option value={line.value}>{line.label}</option>
                  ))}
                </select>
              </label>
              <label>
                Модель или конфигурация
                <input name="model" type="text" placeholder="Например: ATM 27" />
              </label>
              <label>
                Количество
                <input name="quantity" type="text" required />
              </label>
              <button type="submit" class="btn btn-secondary" data-track-event="lead_form_quote_submit">
                Запросить КП
              </button>
            </form>
          </article>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    const buildMailtoBody = (values) =>
      Object.entries(values)
        .filter(([, value]) => String(value || "").trim())
        .map(([key, value]) => `${key}: ${value}`)
        .join("\n");

    const formToObject = (form) => {
      const data = new FormData(form);
      return Object.fromEntries(data.entries());
    };

    const openMailClient = (subject, payload) => {
      const body = buildMailtoBody(payload);
      const href = `mailto:info@saga-tech.ru?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = href;
    };

    document.querySelectorAll("[data-lead-form]").forEach((formNode) => {
      formNode.addEventListener("submit", (event) => {
        event.preventDefault();
        const form = event.currentTarget;
        if (!(form instanceof HTMLFormElement)) return;
        if (!form.reportValidity()) return;

        const type = form.getAttribute("data-lead-form");
        const values = formToObject(form);
        const subject =
          type === "quote"
            ? "Запрос КП с сайта SAGA"
            : "Запрос на обсуждение проекта с сайта SAGA";

        if (window.sagaTrack) {
          window.sagaTrack(type === "quote" ? "lead_quote_submit" : "lead_project_submit", {
            line: values.line || "",
          });
        }
        openMailClient(subject, values);
      });
    });
  </script>
</BaseLayout>

