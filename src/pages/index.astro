        text: "Решение для зарядной инфраструктуры с акцентом на современную промышленную подачу и понятное позиционирование в единой линейке продуктов.",
        image: withBase("/assets/charging_stations/se180_front.jpg"),
        bullets: [
          "Отдельное направление продуктовой линейки.",
          "Современный индустриальный образ.",
          "Подходит для расширения сайта за пределы банковского оборудования.",
          "Логично встраивается в единую витрину решений.",
        ],
        details: [
          "Эта карточка помогает показать, что сайт может масштабироваться на новые направления без изменения основного UX.",
          "При добавлении новых станций они просто появятся горизонтально рядом с текущей моделью.",
        ],
        booklet: null,
      },
    ],
  },
];

const sections = [
  { id: "hero", label: "Главный экран" },
  ...deviceSections.map((section) => ({ id: section.id, label: section.navLabel })),
  { id: "advantages", label: "Преимущества" },
  { id: "company", label: "Компания" },
  { id: "contacts", label: "Контакты" },
];
---

<BaseLayout
  title="SAGA — Российские решения самообслуживания"
  description="АО «САГА Технологии» — банкоматы, кассы самообслуживания, СУО, ADM, инфокиоски и зарядные станции."
>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="#hero" aria-label="SAGA">
        <img
          src={withBase("/assets/logos/saga_logo_black.svg")}
          alt="SAGA"
          class="brand-logo"
        />
      </a>

      <nav class="main-nav" aria-label="Основная навигация">
        {navItems.map((item) => (
          <a href={item.href} class="nav-link">{item.label}</a>
        ))}
      </nav>

      <a class="header-cta" href="#contacts">Связаться</a>

      <button class="menu-toggle" type="button" aria-label="Открыть меню">
        <span></span>
        <span></span>
      </button>
    </div>

    <div class="mobile-nav">
      <nav class="mobile-nav-inner" aria-label="Мобильная навигация">
        {navItems.map((item) => (
          <a href={item.href} class="mobile-nav-link">{item.label}</a>
        ))}
        <a href="#contacts" class="mobile-nav-link mobile-nav-link-accent">Связаться</a>
      </nav>
    </div>
  </header>

  <aside class="section-dots" aria-label="Навигация по разделам">
    {sections.map((section, index) => (
      <a
        href={`#${section.id}`}
        class={`section-dot ${index === 0 ? "is-active" : ""}`}
        data-dot={section.id}
        aria-label={section.label}
      ></a>
    ))}
  </aside>

  <main class="snap-shell" id="snap-shell">
    <section class="screen hero-screen" id="hero" data-section>
      <video
        class="hero-video"
        src={withBase("/assets/promo_atm.mp4")}
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
      <div class="hero-overlay"></div>

      <div class="container hero-content">
        <div class="eyebrow reveal">SAGA TECHNOLOGIES</div>

        <h1 class="hero-title reveal reveal-delay-1">
          Платформа
          <br />
          устройств самообслуживания
        </h1>

        <p class="hero-text reveal reveal-delay-2">
          Полноэкранная продуктовая витрина для коллег и заказчиков: вертикальный
          переход между типами решений и горизонтальное сравнение моделей внутри
          каждой категории.
        </p>

        <div class="hero-actions reveal reveal-delay-3">
          <a href="#atm" class="btn btn-primary">Открыть каталог</a>
          <a href="#contacts" class="btn btn-secondary">Обсудить проект</a>
        </div>
      </div>
    </section>

    {deviceSections.map((category, categoryIndex) => (
      <section class="screen panel-screen product-screen" id={category.id} data-section>
        <div class="container product-screen-inner">
          <div class={`product-screen-head reveal reveal-delay-${Math.min((categoryIndex % 3) + 1, 3)}`}>
            <div class="eyebrow">{category.eyebrow}</div>
            <h2>{category.title}</h2>
            <p>{category.intro}</p>

            <div class="product-screen-meta">
              <span class="product-chip">{category.slides.length} моделей в разделе</span>
              <span class="product-chip">Вертикальный переход между категориями</span>
              <span class="product-chip">Горизонтальный свайп внутри линейки</span>
              {category.sectionBooklet && (
                <a
                  class="product-chip product-chip-link"
                  href={category.sectionBooklet}
                  target="_blank"
                  rel="noopener"
                >
                  Общий PDF
                </a>
              )}
            </div>
          </div>

          {category.features?.length ? (
            <div class="feature-media-grid reveal reveal-delay-2">
              {category.features.map((feature) => (
                <article class="feature-media-card">
                  {feature.type === "video" ? (
                    <video
                      src={feature.src}
                      autoplay
                      muted
                      loop
                      playsinline
                      preload="metadata"
                    ></video>
                  ) : (
                    <img src={feature.src} alt={feature.title} loading="lazy" />
                  )}

                  <div class="feature-media-overlay">
                    <div class="feature-kicker">Подача продукта</div>
                    <h3>{feature.title}</h3>
                    <p>{feature.text}</p>
                  </div>
                </article>
              ))}
            </div>
          ) : null}

          <div class="carousel-shell reveal reveal-delay-3" data-carousel-wrap data-count={category.slides.length}>
            <div class="carousel-topbar">
              <div class="carousel-meta">
                <span class="product-chip">Свайп влево/вправо для переключения</span>
                <span class="product-chip">Карточки с раскрывающимися подробностями</span>
              </div>

              <div class="carousel-controls">
                <button type="button" class="carousel-btn" data-carousel-prev aria-label="Предыдущая модель">
                  <span>←</span>
                </button>
                <button type="button" class="carousel-btn" data-carousel-next aria-label="Следующая модель">
                  <span>→</span>
                </button>
              </div>
            </div>

            <div
              class="product-carousel"
              data-carousel
              tabindex="0"
              aria-label={`Модели категории ${category.navLabel}`}
            >
              {category.slides.map((slide) => (
                <article class="device-card" data-slide>
                  <div class="device-card-media">
                    <img src={slide.image} alt={slide.title} loading="lazy" />
                    <div class="device-card-badge">{slide.subtitle}</div>
                  </div>

                  <div class="device-card-body">
                    <div class="device-card-kicker">{category.eyebrow}</div>
                    <h3>{slide.title}</h3>
                    <p>{slide.text}</p>

                    <ul>
                      {slide.bullets.map((bullet) => (
                        <li>{bullet}</li>
                      ))}
                    </ul>

                    <div class="device-card-actions">
                      <details class="device-details">
                        <summary>Подробнее</summary>
                        <div class="device-details-body">
                          {slide.details.map((item) => (
                            <p>{item}</p>
                          ))}
                        </div>
                      </details>

                      <div class="device-action-row">
                        {slide.booklet && (
                          <a
                            class="btn btn-ghost"
                            href={slide.booklet}
                            target="_blank"
                            rel="noopener"
                          >
                            Скачать PDF
                          </a>
                        )}
                        <a class="btn btn-primary" href="#contacts">Обсудить проект</a>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>

            <div class="carousel-nav" aria-label="Навигация по слайдам">
              <div class="carousel-dots">
                {category.slides.map((slide, index) => (
                  <button
                    type="button"
                    class={`carousel-dot ${index === 0 ? "is-active" : ""}`}
                    data-carousel-dot={index}
                    aria-label={slide.title}
                  ></button>
                ))}
              </div>

              <span class="carousel-count" data-carousel-count>
                1 / {category.slides.length}
              </span>
            </div>
          </div>
        </div>
      </section>
    ))}

    <section class="screen panel-screen" id="advantages" data-section>
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Преимущества</div>
          <h2>Один UX-каркас для всей линейки решений.</h2>
          <p>
            Вместо разрозненных карточек сайт теперь работает как единая продуктовая
            система: вертикально пользователь переходит между типами оборудования,
            а горизонтально сравнивает конкретные исполнения.
          </p>
        </div>

        <div class="trust-layout">
          <div class="trust-stats">
            {trustItems.map((item, idx) => (
              <div class={`trust-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
                <div class="trust-value">{item.value}</div>
                <div class="trust-label">{item.label}</div>
              </div>
            ))}
          </div>

          <div class="badge-strip reveal reveal-delay-2">
            {badges.map((badge) => (
              <div class="badge-chip">
                <img src={badge.image} alt={badge.name} loading="lazy" />
                <span>{badge.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="company" data-section>
      <div class="container company-layout">
        <div class="company-copy reveal">
          <div class="eyebrow">Компания</div>
          <h2>От идеи до производства и сервисной поддержки.</h2>
          <p>
            АО «САГА Технологии» основано в 2006 году. Сайт теперь показывает не
            только отдельные продукты, но и целостный производственный контур —
            от разработки до серийного выпуска.
          </p>
          <p>
            Это создаёт правильный уровень доверия уже в первые минуты просмотра:
            виден продукт, видна вариативность линейки и видно, что за ней стоит
            реальное производство.
          </p>

          <div class="hero-actions">
            <a href="#contacts" class="btn btn-primary">Связаться с нами</a>
          </div>
        </div>

        <div class="company-media-grid">
          <div class="company-visual reveal reveal-delay-1">
            <img
              src={withBase("/assets/atms/saga_atm_32_front.jpg")}
              alt="Флагманский банкомат SAGA"
              loading="lazy"
            />
          </div>

          <article class="company-media-card reveal reveal-delay-2">
            <video
              src={withBase("/assets/factory_saga_1.mp4")}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            ></video>
            <div class="feature-media-overlay">
              <div class="feature-kicker">Производство</div>
              <h3>Реальная производственная база</h3>
              <p>
                Видео с производства усиливает доверие к бренду и связывает
                продуктовую витрину с реальным производственным контуром.
              </p>
            </div>
          </article>

          <article class="company-media-card reveal reveal-delay-3">
            <video
              src={withBase("/assets/factory_saga_2.mp4")}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            ></video>
            <div class="feature-media-overlay">
              <div class="feature-kicker">Инженерия</div>
              <h3>Системная разработка и выпуск</h3>
              <p>
                Такой блок помогает коллегам и партнёрам быстро считать масштаб,
                зрелость и industrial feel компании.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="screen panel-screen contact-screen" id="contacts" data-section>
      <div class="container contact-layout">
        <div class="section-copy reveal">
          <div class="eyebrow">Контакты</div>
          <h2>Быстрый выход на контакт без перегруза.</h2>
          <p>
            Финальный экран завершает просмотр каталога и даёт понятные действия:
            позвонить, написать или перейти в основные каналы коммуникации.
          </p>
        </div>

        <div class="contact-card reveal reveal-delay-1">
          <div class="contact-group">
            <div class="contact-kicker">Телефоны</div>
            <a href="tel:+78002222197" class="contact-link">8 800 222-21-97</a>
            <a href="tel:+74959871121" class="contact-link">7 495 987-11-21</a>
          </div>

          <div class="contact-group">
            <div class="contact-kicker">Почта</div>
            <a href="mailto:info@saga-tech.ru" class="contact-link">info@saga-tech.ru</a>
            <a href="mailto:press@sagacorporation.com" class="contact-link">
              press@sagacorporation.com
            </a>
          </div>

          <div class="contact-group">
            <div class="contact-kicker">Адреса</div>
            <div class="contact-text">Москва, ул. Бутырская, д. 62, 21 этаж</div>
            <div class="contact-text">Москва, ул. Верейская, д. 42, стр. 5</div>
            <div class="contact-text">Московская область, Дубна, пр-т Науки, д. 96</div>
            <div class="contact-text">Москва, 8 Марта, д. 2, стр. 8</div>
          </div>

          <div class="contact-icons">
            {contactIcons.map((item) => (
              <a
                href={item.href}
                class="contact-icon"
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noopener" : undefined}
                aria-label={item.label}
              >
                <img src={item.icon} alt="" loading="lazy" />
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    const root = document.documentElement;
    const sectionNodes = Array.from(document.querySelectorAll("[data-section]"));
    const dots = Array.from(document.querySelectorAll("[data-dot]"));
    const menuToggle = document.querySelector(".menu-toggle");
    const header = document.querySelector(".site-header");
    const mobileLinks = Array.from(document.querySelectorAll(".mobile-nav-link"));
    const navLinks = Array.from(document.querySelectorAll('a[href^="#"]'));
    const revealEls = Array.from(document.querySelectorAll(".reveal"));
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    const setActiveSection = (id) => {
      dots.forEach((dot) => {
        dot.classList.toggle("is-active", dot.getAttribute("data-dot") === id);
      });
    };

    if (!prefersReducedMotion.matches) {
      root.classList.add("reveal-ready");

      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );

      revealEls.forEach((el) => revealObserver.observe(el));
    } else {
      revealEls.forEach((el) => el.classList.add("is-visible"));
    }

    const sectionObserver = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible?.target?.id) {
          setActiveSection(visible.target.id);
        }
      },
      { threshold: [0.35, 0.6, 0.85] }
    );

    sectionNodes.forEach((section) => sectionObserver.observe(section));

    const closeMenu = () => header?.classList.remove("is-open");

    if (menuToggle && header) {
      menuToggle.addEventListener("click", () => {
        header.classList.toggle("is-open");
      });
    }

    [...mobileLinks, ...navLinks].forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = link.getAttribute("href");
        if (!href || !href.startsWith("#")) return;

        const target = document.querySelector(href);
        if (!target) return;

        e.preventDefault();
        closeMenu();

        target.scrollIntoView({
          behavior: prefersReducedMotion.matches ? "auto" : "smooth",
          block: "start",
        });
      });
    });

    const carouselWraps = Array.from(document.querySelectorAll("[data-carousel-wrap]"));

    const setupCarousel = (wrap) => {
      const carousel = wrap.querySelector("[data-carousel]");
      const slides = Array.from(wrap.querySelectorAll("[data-slide]"));
      const prev = wrap.querySelector("[data-carousel-prev]");
      const next = wrap.querySelector("[data-carousel-next]");
      const dots = Array.from(wrap.querySelectorAll("[data-carousel-dot]"));
      const count = wrap.querySelector("[data-carousel-count]");

      if (!carousel || !slides.length) return;

      const getActiveIndex = () => {
        let activeIndex = 0;
        let minDiff = Infinity;

        slides.forEach((slide, index) => {
          const diff = Math.abs(slide.offsetLeft - carousel.scrollLeft);
          if (diff < minDiff) {
            minDiff = diff;
            activeIndex = index;
          }
        });

        return activeIndex;
      };

      const goTo = (index) => {
        const target = slides[Math.max(0, Math.min(index, slides.length - 1))];
        if (!target) return;

        carousel.scrollTo({
          left: target.offsetLeft,
          behavior: prefersReducedMotion.matches ? "auto" : "smooth",
        });
      };

      const render = () => {
        const activeIndex = getActiveIndex();

        dots.forEach((dot, index) => {
          dot.classList.toggle("is-active", index === activeIndex);
        });

        if (count) {
          count.textContent = `${activeIndex + 1} / ${slides.length}`;
        }

        if (prev) prev.disabled = activeIndex === 0;
        if (next) next.disabled = activeIndex === slides.length - 1;
      };

      prev?.addEventListener("click", () => {
        goTo(getActiveIndex() - 1);
      });

      next?.addEventListener("click", () => {
        goTo(getActiveIndex() + 1);
      });

      dots.forEach((dot, index) => {
        dot.addEventListener("click", () => goTo(index));
      });

      let rafId = null;
      carousel.addEventListener(
        "scroll",
        () => {
          if (rafId) cancelAnimationFrame(rafId);
          rafId = requestAnimationFrame(render);
        },
        { passive: true }
      );

      carousel.addEventListener(
        "wheel",
        (e) => {
          if (window.innerWidth <= 860) return;
          if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) return;
          if (carousel.scrollWidth <= carousel.clientWidth) return;

          e.preventDefault();
          carousel.scrollBy({ left: e.deltaY, behavior: "auto" });
        },
        { passive: false }
      );

      window.addEventListener("resize", render);
      render();
    };

    carouselWraps.forEach(setupCarousel);

    if (prefersReducedMotion.matches) {
      document.querySelectorAll("video").forEach((video) => {
        video.removeAttribute("autoplay");
      });
    }
  </script>
</BaseLayout>
