---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const withBase = (path) => `${base}${path.replace(/^\/+/, "")}`;

const navItems = [
  { label: "Продукты", href: "#products" },
  { label: "Преимущества", href: "#advantages" },
  { label: "Отрасли", href: "#industries" },
  { label: "Компания", href: "#company" },
  { label: "Контакты", href: "#contacts" },
];

const products = [
  {
    key: "atm",
    title: "Банкоматы SAGA",
    text: "Линейка банкоматов для банковской инфраструктуры с современным промышленным исполнением и поддержкой разных сценариев самообслуживания.",
    bullets: [
      "Модели 19, 27 и 32 дюйма.",
      "Подходят для банковских отделений и зон 24/7.",
      "Надежная промышленная архитектура.",
      "Готовность к масштабированию парка устройств.",
    ],
    image: withBase("/assets/atms/saga_atm_27_front.jpg"),
    booklet: withBase("/assets/booklets/atm_booklet.pdf"),
  },
  {
    key: "queue",
    title: "Системы управления очередью",
    text: "Решения для организации клиентского потока в отделениях, сервисных офисах и общественных пространствах.",
    bullets: [
      "Интуитивный пользовательский сценарий.",
      "Чистый интерфейс и заметная навигация.",
      "Подходят для высокой нагрузки.",
      "Легко встраиваются в действующую инфраструктуру.",
    ],
    image: withBase("/assets/qms/syo_27_saga_front.jpg"),
    booklet: withBase("/assets/booklets/qms_booklet.pdf"),
  },
  {
    key: "selfcheckout",
    title: "Кассы самообслуживания SAGA",
    text: "Оборудование для самостоятельной оплаты товаров и услуг с акцентом на устойчивую работу и удобство пользователя.",
    bullets: [
      "Подходят для ритейла и сервисных точек.",
      "Поддержка POS-периферии.",
      "Эргономичный форм-фактор.",
      "Готовность к серийному развертыванию.",
    ],
    image: withBase("/assets/ssc/ssc_21_front_2.jpg"),
    booklet: withBase("/assets/booklets/ssc_booklet.pdf"),
  },
];

const trustItems = [
  { value: "2006", label: "Год основания компании." },
  { value: "Full cycle", label: "Разработка, производство и сервисная поддержка." },
  { value: "RU", label: "Российская инженерная и производственная база." },
  { value: "B2B", label: "Решения для банков, ритейла и госсектора." },
];

const industries = [
  "Банки",
  "Ритейл",
  "Госсектор",
  "Транспорт",
  "Сервисные пространства",
  "Корпоративная инфраструктура",
];

const badges = [
  { name: "Резидент", image: withBase("/assets/logos/Rezident_TM.png") },
  { name: "Национальные чемпионы", image: withBase("/assets/logos/national_champions.png") },
  { name: "КВТ", image: withBase("/assets/logos/logo_kvt.png") },
  { name: "ANDO", image: withBase("/assets/logos/logo-small_ando_v3.png") },
];

const contactIcons = [
  {
    label: "Телефон",
    href: "tel:+78002222197",
    icon: withBase("/assets/logos/телефон-logo.png"),
  },
  {
    label: "Почта",
    href: "mailto:info@saga-tech.ru",
    icon: withBase("/assets/logos/почта_logo.png"),
  },
  {
    label: "Telegram",
    href: "https://t.me/SAGACorporation",
    icon: withBase("/assets/logos/tg_logo.png"),
  },
  {
    label: "MAX",
    href: "https://max.ru/id7718589473biz",
    icon: withBase("/assets/logos/Max_logo_2025.png"),
  },
  {
    label: "VK",
    href: "https://vk.com/sagatech",
    icon: withBase("/assets/logos/VK Logo.png"),
  },
];

const sections = [
  { id: "hero", label: "Hero" },
  { id: "products", label: "Продукты" },
  { id: "advantages", label: "Преимущества" },
  { id: "industries", label: "Отрасли" },
  { id: "company", label: "Компания" },
  { id: "contacts", label: "Контакты" },
];
---

<BaseLayout
  title="SAGA — Российские решения самообслуживания"
  description="АО «САГА Технологии» — банкоматы, кассы самообслуживания и системы управления очередью."
>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="#hero" aria-label="SAGA">
        <img
          src={withBase("/assets/logos/saga_logo_black.svg")}
          alt="SAGA"
          class="brand-logo"
        />
      </a>

      <nav class="main-nav" aria-label="Основная навигация">
        {navItems.map((item) => (
          <a href={item.href} class="nav-link">{item.label}</a>
        ))}
      </nav>

      <a class="header-cta" href="#contacts">Связаться</a>

      <button class="menu-toggle" type="button" aria-label="Открыть меню">
        <span></span>
        <span></span>
      </button>
    </div>

    <div class="mobile-nav">
      <nav class="mobile-nav-inner" aria-label="Мобильная навигация">
        {navItems.map((item) => (
          <a href={item.href} class="mobile-nav-link">{item.label}</a>
        ))}
        <a href="#contacts" class="mobile-nav-link mobile-nav-link-accent">Связаться</a>
      </nav>
    </div>
  </header>

  <aside class="section-dots" aria-label="Навигация по разделам">
    {sections.map((section, index) => (
      <a
        href={`#${section.id}`}
        class={`section-dot ${index === 0 ? "is-active" : ""}`}
        data-dot={section.id}
        aria-label={section.label}
      ></a>
    ))}
  </aside>

  <main class="snap-shell" id="snap-shell">
    <section class="screen hero-screen" id="hero" data-section>
      <video
        class="hero-video"
        src={withBase("/assets/promo_atm.mp4")}
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
      <div class="hero-overlay"></div>

      <div class="container hero-content">
        <div class="eyebrow reveal">SAGA TECHNOLOGIES</div>

        <h1 class="hero-title reveal reveal-delay-1">
          Российские решения
          <br />
          самообслуживания
        </h1>

        <p class="hero-text reveal reveal-delay-2">
          АО «САГА Технологии» разрабатывает и выпускает банкоматы, кассы
          самообслуживания и системы управления очередью для банков, ритейла,
          госсектора и сервисных пространств.
        </p>

        <div class="hero-actions reveal reveal-delay-3">
          <a href="#products" class="btn btn-primary">Смотреть решения</a>
          <a href="#contacts" class="btn btn-secondary">Связаться</a>
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="products" data-section>
      <div class="container panel-grid panel-grid-wide">
        <div class="section-copy reveal">
          <div class="eyebrow">Продукты</div>
          <h2>Три направления. Один инженерный подход.</h2>
          <p>
            Мы показываем оборудование крупно, чисто и без визуального шума:
            сначала суть, потом детали, документы и сценарии применения.
          </p>
        </div>

        <div class="products-grid">
          {products.map((product, idx) => (
            <article class={`product-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
              <div class="product-media">
                <img src={product.image} alt={product.title} loading="lazy" />
              </div>

              <div class="product-body">
                <h3>{product.title}</h3>
                <p>{product.text}</p>

                <ul>
                  {product.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>

                <div class="product-actions">
                  <a class="text-link" href={product.booklet} target="_blank" rel="noopener">
                    Скачать PDF
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="advantages" data-section>
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Преимущества</div>
          <h2>Опыт, производство и зрелые сценарии.</h2>
          <p>
            Первый уровень доверия должен считываться за несколько секунд:
            опыт, производство, отрасли применения и зрелость решений.
          </p>
        </div>

        <div class="trust-layout">
          <div class="trust-stats">
            {trustItems.map((item, idx) => (
              <div class={`trust-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
                <div class="trust-value">{item.value}</div>
                <div class="trust-label">{item.label}</div>
              </div>
            ))}
          </div>

          <div class="badge-strip reveal reveal-delay-2">
            {badges.map((badge) => (
              <div class="badge-chip">
                <img src={badge.image} alt={badge.name} loading="lazy" />
                <span>{badge.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="industries" data-section>
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Отрасли</div>
          <h2>Где и зачем применяется оборудование.</h2>
          <p>
            Вместо длинных текстов — матрица сценариев. Пользователь сразу
            понимает, где и зачем применяется оборудование.
          </p>
        </div>

        <div class="industries-grid">
          {industries.map((item, idx) => (
            <div class={`industry-card reveal reveal-delay-${Math.min((idx % 3) + 1, 3)}`}>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="company" data-section>
      <div class="container company-layout">
        <div class="company-copy reveal">
          <div class="eyebrow">Компания</div>
          <h2>От идеи до серийного производства.</h2>
          <p>
            АО «САГА Технологии» основано в 2006 году. Мы сопровождаем весь цикл —
            от разработки и опытно-конструкторских работ до серийного производства
            и сервисной поддержки.
          </p>
          <p>
            Такой раздел можно позже вынести в отдельную страницу без полной
            переделки сайта: архитектура уже готова к росту.
          </p>

          <div class="hero-actions">
            <a href="#contacts" class="btn btn-primary">Связаться с нами</a>
          </div>
        </div>

        <div class="company-visual reveal reveal-delay-2">
          <img
            src={withBase("/assets/atms/saga_atm_32_front.jpg")}
            alt="Банкомат SAGA"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <section class="screen panel-screen contact-screen" id="contacts" data-section>
      <div class="container contact-layout">
        <div class="section-copy reveal">
          <div class="eyebrow">Контакты</div>
          <h2>Быстрый контакт без перегруза.</h2>
          <p>
            Удобный финальный экран без перегруза: быстрые действия, контакты и
            адреса, которые читаются за один взгляд.
          </p>
        </div>

        <div class="contact-card reveal reveal-delay-1">
          <div class="contact-group">
            <div class="contact-kicker">Телефоны</div>
            <a href="tel:+78002222197" class="contact-link">8 800 222-21-97</a>
            <a href="tel:+74959871121" class="contact-link">7 495 987-11-21</a>
          </div>

          <div class="contact-group">
            <div class="contact-kicker">Почта</div>
            <a href="mailto:info@saga-tech.ru" class="contact-link">info@saga-tech.ru</a>
            <a href="mailto:press@sagacorporation.com" class="contact-link">
              press@sagacorporation.com
            </a>
          </div>

          <div class="contact-group">
            <div class="contact-kicker">Адреса</div>
            <div class="contact-text">Москва, ул. Бутырская, д. 62, 21 этаж</div>
            <div class="contact-text">Москва, ул. Верейская, д. 42, стр. 5</div>
            <div class="contact-text">Московская область, Дубна, пр-т Науки, д. 96</div>
            <div class="contact-text">Москва, ул. 8 Марта, д. 2, стр. 8</div>
          </div>

          <div class="contact-icons">
            {contactIcons.map((item) => (
              <a
                href={item.href}
                class="contact-icon"
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noopener" : undefined}
                aria-label={item.label}
              >
                <img src={item.icon} alt="" loading="lazy" />
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    const root = document.documentElement;
    const sections = Array.from(document.querySelectorAll("[data-section]"));
    const dots = Array.from(document.querySelectorAll("[data-dot]"));
    const menuToggle = document.querySelector(".menu-toggle");
    const header = document.querySelector(".site-header");
    const mobileLinks = Array.from(document.querySelectorAll(".mobile-nav-link"));
    const navLinks = Array.from(document.querySelectorAll('a[href^="#"]'));
    const revealEls = Array.from(document.querySelectorAll(".reveal"));
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    const setActiveSection = (id) => {
      dots.forEach((dot) => {
        dot.classList.toggle("is-active", dot.getAttribute("data-dot") === id);
      });
    };

    if (!prefersReducedMotion.matches) {
      root.classList.add("reveal-ready");

      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );

      revealEls.forEach((el) => revealObserver.observe(el));
    } else {
      revealEls.forEach((el) => el.classList.add("is-visible"));
    }

    const sectionObserver = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible?.target?.id) {
          setActiveSection(visible.target.id);
        }
      },
      { threshold: [0.35, 0.6, 0.85] }
    );

    sections.forEach((section) => sectionObserver.observe(section));

    const closeMenu = () => header?.classList.remove("is-open");

    if (menuToggle && header) {
      menuToggle.addEventListener("click", () => {
        header.classList.toggle("is-open");
      });
    }

    [...mobileLinks, ...navLinks].forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = link.getAttribute("href");
        if (!href || !href.startsWith("#")) return;

        const target = document.querySelector(href);
        if (!target) return;

        e.preventDefault();
        closeMenu();

        target.scrollIntoView({
          behavior: prefersReducedMotion.matches ? "auto" : "smooth",
          block: "start",
        });
      });
    });

    if (prefersReducedMotion.matches) {
      document.querySelectorAll("video").forEach((video) => {
        video.removeAttribute("autoplay");
      });
    }
  </script>
</BaseLayout>
