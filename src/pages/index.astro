---
import BaseLayout from "../layouts/BaseLayout.astro";
import { deviceSections } from "../data/categories";
import { getProductsByCategory, type Product } from "../data/products";
import { Image } from "astro:assets";
import ProductCarouselIsland from "../components/ProductCarouselIsland.jsx";
import ImageLightboxIsland from "../components/ImageLightboxIsland.jsx";
import heroImage from "../assets/presentation/wine_saga_atm32.png";

const base = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${base.replace(/\/+$/, "")}/${path.replace(/^\/+/, "")}`;
const resolveImageHref = (href?: string | null) => {
  if (!href) return "";
  if (/^(?:https?:)?\/\//.test(href) || href.startsWith("data:") || href.startsWith("blob:")) {
    return href;
  }
  const normalizedBase = base.replace(/\/+$/, "");
  if (normalizedBase && (href === normalizedBase || href.startsWith(`${normalizedBase}/`))) {
    return href;
  }
  return href.startsWith("/") ? withBase(href) : withBase(`/${href}`);
};

const resolveBookletHref = (href?: string | null) => {
  if (!href) return null;
  // В JSON иногда хранится абсолютный путь к ассету без base.
  if (href.startsWith("/assets/")) return withBase(href);
  return href;
};

const navItems = [
  { label: "Продукты", href: "#atm" },
  { label: "Решения", href: withBase("/solutions") },
  { label: "Оборудование", href: withBase("/equipment") },
  { label: "Новости", href: withBase("/news") },
  { label: "Контакты", href: "#contacts" },
];

const trustItems = [
  { value: "2006", label: "Год основания компании." },
  { value: "Full cycle", label: "Разработка, производство и сервисная поддержка." },
  { value: "RU", label: "Российская инженерная и производственная база." },
  { value: "B2B", label: "Решения для банков, ритейла и инфраструктурных проектов." },
];

const badges = [
  { name: "Резидент технополис «Москва»", image: withBase("/assets/logos/Rezident_TM.png") },
  { name: "Член ассоциации быстрорастущих технологических компаний «Национальные чемпионы»", image: withBase("/assets/logos/national_champions.png") },
  { name: "Партнёр консорциума Вычислительная техника", image: withBase("/assets/logos/logo_kvt.png") },
  { name: "Член ассоциации организаций в сфере наличного денежного обращения, инкассации и перевозки ценностей", image: withBase("/assets/logos/logo-small_ando_v3.png") },
];

const contactIcons = [
  {
    label: "Телефон",
    href: "tel:+78002222197",
    icon: withBase("/assets/logos/телефон-logo.png"),
  },
  {
    label: "Почта",
    href: "mailto:info@saga-tech.ru",
    icon: withBase("/assets/logos/почта_logo.png"),
  },
  {
    label: "Telegram",
    href: "https://t.me/SAGACorporation",
    icon: withBase("/assets/logos/tg_logo.png"),
  },
  {
    label: "MAX",
    href: "https://max.ru/id7718589473biz",
    icon: withBase("/assets/logos/Max_logo_2025.png"),
  },
  {
    label: "VK",
    href: "https://vk.com/sagatech",
    icon: withBase("/assets/logos/VK Logo.png"),
  },
];

const sections = [
  { id: "hero", label: "Главный экран" },
  ...deviceSections.map((section) => ({ id: section.id, label: section.navLabel })),
  { id: "advantages", label: "Преимущества" },
  { id: "company", label: "Компания" },
  { id: "contacts", label: "Контакты" },
];

const sectionsWithProducts: (typeof deviceSections[number] & { products: Product[] })[] =
  deviceSections.map((section) => ({
    ...section,
    products: getProductsByCategory(section.id),
  }));
---

<BaseLayout
  title="SAGA — Российские решения самообслуживания"
  description="АО «САГА Технологии» — банкоматы, кассы самообслуживания, СУО, ADM, инфокиоски и зарядные станции."
>
  <header class="site-header">
    <div class="container header-inner">
      <div class="header-row">
        <a class="brand" href="#hero" aria-label="SAGA">
          <img
            src={withBase("/assets/logos/saga_logo_black.svg")}
            alt="SAGA"
            class="brand-logo"
          />
        </a>

        <nav class="main-nav" aria-label="Основная навигация">
          {navItems.map((item) => (
            <a href={item.href} class="nav-link">{item.label}</a>
          ))}
        </nav>

        <button class="menu-toggle" type="button" aria-label="Открыть меню">
          <span></span>
          <span></span>
        </button>
      </div>

      <div class="mobile-nav">
        <nav class="mobile-nav-inner" aria-label="Мобильная навигация">
          {navItems.map((item) => (
            <a href={item.href} class="mobile-nav-link">{item.label}</a>
          ))}
          <a href="#contacts" class="mobile-nav-link mobile-nav-link-accent" data-open-lead-modal>Связаться</a>
        </nav>
      </div>
    </div>
  </header>

  <aside class="section-dots" aria-label="Навигация по разделам">
    {sections.map((section, index) => (
      <a
        href={`#${section.id}`}
        class={`section-dot-link ${index === 0 ? "is-active" : ""}`}
        data-dot={section.id}
        aria-label={section.label}
      >
        <span class="section-dot-label" aria-hidden="true">{section.label}</span>
        <span class="section-dot" aria-hidden="true"></span>
      </a>
    ))}
  </aside>

  <main class="snap-shell" id="snap-shell">
    <section class="screen hero-screen" id="hero" data-section>
      <Image
        src={heroImage}
        alt="SAGA — устройства самообслуживания"
        class="hero-video"
      />
      <div class="hero-overlay"></div>

      <div class="container hero-content">
        <div class="eyebrow reveal">САГА Технологии</div>

        <h1 class="hero-title reveal reveal-delay-1">
          Платформа
          <br />
          устройств самообслуживания
        </h1>

        <p class="hero-text reveal reveal-delay-2">
          Российский производитель банкоматов, платежных терминалов, касс
          самообслуживания, систем управления очередью и другого
          высокотехнологичного оборудования. Полный цикл: от разработки
          до серийного производства и сервисной поддержки.
        </p>

        <div class="hero-actions reveal reveal-delay-3">
          <a href={withBase("/company")} class="btn btn-secondary btn-hero" data-track-event="hero_about">
            О компании
          </a>
          <a
            href="#contacts"
            class="btn btn-secondary btn-hero"
            data-open-lead-modal
            data-track-event="hero_discuss_project"
          >
            Обсудить проект
          </a>
          <a href="#atm" class="btn btn-secondary btn-hero" data-track-event="hero_open_catalog">
            Открыть каталог
          </a>
        </div>
      </div>
    </section>

    {sectionsWithProducts.map((category, categoryIndex) => (
      <section class="screen panel-screen product-screen" id={category.id} data-section>
        <div class="container product-screen-inner">
          <div class={`product-screen-head reveal reveal-delay-${Math.min((categoryIndex % 3) + 1, 3)}`}>
            <div class="eyebrow">{category.eyebrow}</div>
            <h2>{category.title}</h2>
            <p>{category.intro}</p>
          </div>

          <div
            class="carousel-shell reveal reveal-delay-3"
            data-carousel-wrap
            data-section-id={category.id}
            data-count={category.products.length}
          >
            <div
              class="product-carousel"
              data-carousel
              tabindex="0"
              aria-label={`Модели категории ${category.navLabel}`}
            >
              {category.products.map((product) => {
                const darkImages = product.images.filter((img) => img.theme === "dark");
                const lightImages = product.images.filter((img) => img.theme === "light");
                const defaultImages = product.images.filter((img) => !img.theme);
                const pickPrimary = (images: Product["images"]) =>
                  images.find((img) => img.slot === "card" || img.isPrimary) ?? images[0];
                const pickGallery = (images: Product["images"]) =>
                  images.filter((img) => img.slot === "gallery" || (!img.slot && !img.isPrimary));

                const darkPrimary = pickPrimary(darkImages);
                const lightPrimary = pickPrimary(lightImages);
                const primaryImage =
                  darkPrimary ?? lightPrimary ?? pickPrimary(defaultImages) ?? product.images[0];
                const darkGallery = pickGallery(darkImages);
                const lightGallery = pickGallery(lightImages);
                const fallbackGallery = defaultImages.length ? defaultImages : product.images;
                const darkLightboxImages = darkGallery.length ? darkGallery : fallbackGallery;
                const lightLightboxImages = lightGallery.length ? lightGallery : fallbackGallery;

                const lightboxStartIndex = 0;
                // Только строковые URL: optimized — объект, JSON.stringify ломает лайтбокс
                const lightboxSrcs = fallbackGallery.map((img) => resolveImageHref(img.src));
                const lightboxAlts = fallbackGallery.map((img) => img.alt || product.title);
                const lightboxSrcsDark = darkLightboxImages.map((img) => resolveImageHref(img.src));
                const lightboxAltsDark = darkLightboxImages.map((img) => img.alt || product.title);
                const lightboxSrcsLight = lightLightboxImages.map((img) => resolveImageHref(img.src));
                const lightboxAltsLight = lightLightboxImages.map((img) => img.alt || product.title);
                return (
                  <article class="device-card" data-slide>
                    <button
                      class="device-card-media device-card-media-trigger"
                      type="button"
                      data-open-lightbox
                      data-lightbox-srcs={JSON.stringify(lightboxSrcs)}
                      data-lightbox-alts={JSON.stringify(lightboxAlts)}
                      data-lightbox-srcs-dark={JSON.stringify(lightboxSrcsDark)}
                      data-lightbox-alts-dark={JSON.stringify(lightboxAltsDark)}
                      data-lightbox-srcs-light={JSON.stringify(lightboxSrcsLight)}
                      data-lightbox-alts-light={JSON.stringify(lightboxAltsLight)}
                      data-lightbox-start-index={lightboxStartIndex}
                      aria-label={`Открыть изображения: ${product.title}`}
                    >
                      {darkPrimary && lightPrimary ? (
                        <>
                          {darkPrimary.optimized ? (
                            <Image
                              src={darkPrimary.optimized}
                              alt={darkPrimary.alt || product.title}
                              loading="lazy"
                              class="theme-image theme-image-dark"
                            />
                          ) : (
                            <img
                              src={resolveImageHref(darkPrimary.src)}
                              alt={darkPrimary.alt || product.title}
                              loading="lazy"
                              class="theme-image theme-image-dark"
                            />
                          )}
                          {lightPrimary.optimized ? (
                            <Image
                              src={lightPrimary.optimized}
                              alt={lightPrimary.alt || product.title}
                              loading="lazy"
                              class="theme-image theme-image-light"
                            />
                          ) : (
                            <img
                              src={resolveImageHref(lightPrimary.src)}
                              alt={lightPrimary.alt || product.title}
                              loading="lazy"
                              class="theme-image theme-image-light"
                            />
                          )}
                        </>
                      ) : (
                        primaryImage && (
                          primaryImage.optimized ? (
                          <Image
                            src={primaryImage.optimized}
                            alt={primaryImage.alt || product.title}
                            loading="lazy"
                          />
                          ) : (
                            <img
                              src={resolveImageHref(primaryImage.src)}
                              alt={primaryImage.alt || product.title}
                              loading="lazy"
                            />
                          )
                        )
                      )}
                    </button>

                  <div class="device-card-body">
                    <div class="device-card-kicker">{category.eyebrow}</div>
                    <h3>{product.title}</h3>
                    <p>{product.intro}</p>

                    <div class="device-card-actions">
                      <div class="device-details-body">
                        <ul class="device-details-list">
                          {product.bullets.map((bullet) => (
                            <li>{bullet}</li>
                          ))}
                        </ul>
                        {product.details.map((item) => (
                          <p>{item}</p>
                        ))}
                      </div>

                      <div class="device-action-row">
                        <a
                          class="btn btn-ghost btn-pdf"
                          href={withBase(`/lines/${category.id}`)}
                          data-track-event="line_open_from_main"
                          aria-label={`Подробнее о линейке ${category.navLabel}`}
                        >
                          <span>Подробнее</span>
                        </a>
                      </div>
                    </div>
                  </div>
                </article>
              );
              })}
            </div>

            <div class="carousel-controls">
              <div class="carousel-control-zone carousel-control-zone-prev" data-carousel-prev-zone>
                <button
                  type="button"
                  class="carousel-btn"
                  data-carousel-prev
                  aria-label="Предыдущая модель"
                >
                  <span>←</span>
                </button>
              </div>
              <div class="carousel-control-zone carousel-control-zone-next" data-carousel-next-zone>
                <button
                  type="button"
                  class="carousel-btn"
                  data-carousel-next
                  aria-label="Следующая модель"
                >
                  <span>→</span>
                </button>
              </div>
            </div>

            <div class="carousel-nav" aria-label="Навигация по слайдам">
              <div class="carousel-dots">
                {category.products.map((product, index) => (
                  <button
                    type="button"
                    class={`carousel-dot ${index === 0 ? "is-active" : ""}`}
                    data-carousel-dot={index}
                    aria-label={product.title}
                  ></button>
                ))}
              </div>
            </div>

            <ProductCarouselIsland client:load sectionId={category.id} />
          </div>
        </div>
      </section>
    ))}

    <section class="screen panel-screen" id="advantages" data-section>
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Преимущества</div>
          <h2>Комплексный подход к решению задач заказчика.</h2>
          <p>
            Стратегия компании охватывает полный цикл: от анализа требований и
            проектирования до производства, внедрения и сервисной поддержки.
            Более 700 моделей и модификаций оборудования для различных отраслей.
          </p>
        </div>

        <div class="trust-layout">
          <div class="trust-stats">
            {trustItems.map((item, idx) => (
              <div class={`trust-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
                <div class="trust-value">{item.value}</div>
                <div class="trust-label">{item.label}</div>
              </div>
            ))}
          </div>

          <div class="badge-strip reveal reveal-delay-2">
            {badges.map((badge) => (
              <div class="badge-chip">
                <img src={badge.image} alt={badge.name} loading="lazy" />
                <span>{badge.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="company" data-section>
      <div class="container company-layout">
        <div class="company-copy reveal">
          <div class="eyebrow">Компания</div>
          <h2>От идеи до производства и сервисной поддержки.</h2>
          <p>
            АО «САГА Технологии» основано в 2006 году. Компания является
            производителем полного цикла и располагает собственными
            площадками в Москве и Московской области, оснащёнными современным
            парком станков для работы со сталью, алюминием и пластиком.
          </p>
          <p>
            Профессиональная команда инженеров, конструкторов, программистов
            и технологов решает сложные и нестандартные задачи в короткие сроки,
            что является ключевой компетенцией компании.
          </p>

          <div class="hero-actions">
            <a href="#contacts" class="btn btn-primary" data-open-lead-modal>Связаться с нами</a>
          </div>
        </div>

        <div class="company-media-grid">


          <article class="company-media-card reveal reveal-delay-2">
            <div class="feature-media-overlay">
              <div class="feature-kicker">Производство</div>
              <h3>Собственная производственная база</h3>
              <p>
                Производственные площадки в Москве и Московской области
                обеспечивают полный цикл изготовления оборудования —
                от металлообработки до финальной сборки.
              </p>
            </div>
            <div class="company-media-card-media">
              <video
                src={withBase("/assets/factory_saga_1.mp4")}
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              ></video>
            </div>
          </article>

          <article class="company-media-card reveal reveal-delay-3">
            <div class="feature-media-overlay">
              <div class="feature-kicker">Инженерия</div>
              <h3>Инженерная экспертиза</h3>
              <p>
                Разработка, конструирование и испытания проводятся силами
                собственной команды, что обеспечивает контроль качества
                на каждом этапе.
              </p>
            </div>
            <div class="company-media-card-media">
              <video
                src={withBase("/assets/factory_saga_2.mp4")}
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              ></video>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="screen panel-screen contact-screen" id="contacts" data-section>
      <div class="container contact-layout">
        <div class="section-copy reveal">
          <div class="eyebrow">Контакты</div>
        </div>

        <div class="contact-card reveal reveal-delay-1">
          <div class="contact-group">
            <div class="contact-kicker">Телефоны</div>
            <a href="tel:+78002222197" class="contact-link">8 800 222-21-97</a>
            <a href="tel:+74959871121" class="contact-link">7 495 987-11-21</a>
          </div>

          <div class="contact-group">
            <div class="contact-kicker">Почта</div>
            <a href="mailto:info@saga-tech.ru" class="contact-link">info@saga-tech.ru</a>
            <div class="contact-kicker">Для прессы</div>
            <a href="mailto:press@sagacorporation.com" class="contact-link">
              press@sagacorporation.com
            </a>
          </div>

          <div class="contact-group">
            <div class="contact-kicker">Адрес</div>
            <div class="contact-text">111622, г. Москва, ул. Большая Косинская, д. 27, строение 16, эт. 5, помещение 508А</div>
            <div class="contact-text">Москва, ул. Уральская, д. 21</div>
          </div>

          <div class="contact-icons">
            {contactIcons.map((item) => (
              <a
                href={item.href}
                class="contact-icon"
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noopener" : undefined}
                aria-label={item.label}
              >
                <img src={item.icon} alt="" loading="lazy" />
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <ImageLightboxIsland client:load />

  <script is:inline>
    const root = document.documentElement;
    const sectionNodes = Array.from(document.querySelectorAll("[data-section]"));
    const dots = Array.from(document.querySelectorAll("[data-dot]"));
    const menuToggle = document.querySelector(".menu-toggle");
    const header = document.querySelector(".site-header");
    const mobileLinks = Array.from(document.querySelectorAll(".mobile-nav-link"));
    const navLinks = Array.from(document.querySelectorAll('a[href^="#"]'));
    const revealEls = Array.from(document.querySelectorAll(".reveal"));
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const heroSection = document.getElementById("hero");
    const heroVideo = document.querySelector(".hero-video");
    const snapShell = document.getElementById("snap-shell");

    const setActiveSection = (id) => {
      dots.forEach((dot) => {
        dot.classList.toggle("is-active", dot.getAttribute("data-dot") === id);
      });
    };

    if (!prefersReducedMotion.matches) {
      root.classList.add("reveal-ready");

      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );

      revealEls.forEach((el) => revealObserver.observe(el));
    } else {
      revealEls.forEach((el) => el.classList.add("is-visible"));
    }

    const sectionObserver = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible?.target?.id) {
          setActiveSection(visible.target.id);
        }
      },
      { threshold: [0.35, 0.6, 0.85] }
    );

    sectionNodes.forEach((section) => sectionObserver.observe(section));

    const initMobileHeroMotion = () => {
      if (!heroSection || !(heroVideo instanceof HTMLElement)) return;

      const mobileQuery = window.matchMedia("(max-width: 860px)");
      const panStart = 14;
      const panEnd = 86;
      const touchProgressFactor = 240;
      let heroPanProgress = 0;
      let rafId = 0;
      let touchStartY = 0;

      const clamp01 = (value) => Math.min(1, Math.max(0, value));
      const setPanFromProgress = () => {
        const objectX = panStart + (panEnd - panStart) * heroPanProgress;
        heroVideo.style.setProperty("--hero-object-x", `${objectX.toFixed(2)}%`);
      };

      const canLockScrollOnHero = () => {
        if (prefersReducedMotion.matches || !mobileQuery.matches) return false;
        if (heroPanProgress >= 1) return false;
        const heroRect = heroSection.getBoundingClientRect();
        return heroRect.top <= 88 && heroRect.bottom > window.innerHeight * 0.45;
      };

      const consumeDownwardScroll = (deltaY) => {
        if (deltaY <= 0 || !canLockScrollOnHero()) return false;
        heroPanProgress = clamp01(heroPanProgress + deltaY / touchProgressFactor);
        setPanFromProgress();
        return true;
      };

      const updateHeroPan = () => {
        rafId = 0;

        if (prefersReducedMotion.matches || !mobileQuery.matches) {
          heroPanProgress = 1;
          setPanFromProgress();
          return;
        }
        setPanFromProgress();
      };

      const scheduleHeroPanUpdate = () => {
        if (rafId) return;
        rafId = window.requestAnimationFrame(updateHeroPan);
      };

      scheduleHeroPanUpdate();
      window.addEventListener("scroll", scheduleHeroPanUpdate, { passive: true });
      window.addEventListener("resize", scheduleHeroPanUpdate);
      snapShell?.addEventListener("scroll", scheduleHeroPanUpdate, { passive: true });
      mobileQuery.addEventListener("change", scheduleHeroPanUpdate);
      prefersReducedMotion.addEventListener("change", scheduleHeroPanUpdate);

      window.addEventListener(
        "wheel",
        (event) => {
          if (consumeDownwardScroll(event.deltaY)) {
            event.preventDefault();
          }
        },
        { passive: false }
      );

      window.addEventListener(
        "touchstart",
        (event) => {
          touchStartY = event.touches[0]?.clientY ?? 0;
        },
        { passive: true }
      );

      window.addEventListener(
        "touchmove",
        (event) => {
          const currentY = event.touches[0]?.clientY ?? touchStartY;
          const deltaY = touchStartY - currentY;
          touchStartY = currentY;
          if (consumeDownwardScroll(deltaY)) {
            event.preventDefault();
          }
        },
        { passive: false }
      );
    };

    initMobileHeroMotion();

    // Десктоп: футер только когда доскроллил до конца (контакты)
    const initFooterVisibility = () => {
      const footer = document.getElementById("site-footer");
      const contactsSection = document.getElementById("contacts");
      if (!footer || !contactsSection) return;

      const updateFooterVisibility = (isIntersecting) => {
        if (window.innerWidth <= 860) footer.classList.add("is-visible");
        else footer.classList.toggle("is-visible", isIntersecting);
      };
      const footerObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => updateFooterVisibility(entry.isIntersecting));
        },
        { threshold: 0.2, rootMargin: "0px 0px -20% 0px" }
      );
      footerObserver.observe(contactsSection);
      if (window.innerWidth <= 860) footer.classList.add("is-visible");
      window.addEventListener("resize", () => {
        footerObserver.disconnect();
        footerObserver.observe(contactsSection);
        updateFooterVisibility(contactsSection.getBoundingClientRect().top < window.innerHeight * 0.8);
      });
    };
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initFooterVisibility, { once: true });
    } else {
      initFooterVisibility();
    }

    const closeMenu = () => header?.classList.remove("is-open");
    const closeMenuOnMove = () => {
      if (header?.classList.contains("is-open")) closeMenu();
    };

    if (menuToggle && header) {
      menuToggle.addEventListener("click", () => {
        header.classList.toggle("is-open");
      });
    }

    snapShell?.addEventListener("scroll", closeMenuOnMove, { passive: true });
    window.addEventListener("scroll", closeMenuOnMove, { passive: true });
    window.addEventListener("touchmove", closeMenuOnMove, { passive: true });

    [...mobileLinks, ...navLinks].forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = link.getAttribute("href");
        if (!href || !href.startsWith("#")) return;

        const target = document.querySelector(href);
        if (!target) return;

        e.preventDefault();
        closeMenu();

        target.scrollIntoView({
          behavior: prefersReducedMotion.matches ? "auto" : "smooth",
          block: "start",
        });
      });
    });

    if (prefersReducedMotion.matches) {
      document.querySelectorAll("video").forEach((video) => {
        video.removeAttribute("autoplay");
      });
    }
  </script>
</BaseLayout>
