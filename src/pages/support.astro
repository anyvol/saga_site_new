---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";
import InnerPageHero from "../components/InnerPageHero.astro";
import InnerPageSection from "../components/InnerPageSection.astro";
import FinalStickyCta from "../components/FinalStickyCta.astro";
---

<BaseLayout
  title="Поддержка SAGA"
  description="Сервисная поддержка устройств самообслуживания: от первичного обслуживания до ремонта и обновлений."
  footerVisible={true}
>
  <InnerPageHeader />
  <main class="snap-shell">
    <InnerPageHero
      eyebrow="Поддержка"
      title="Поддержка, которая держит вашу сеть в рабочем состоянии."
      text="Решаем сервисные задачи полного цикла: от брендирования и установки до настройки ПО, диагностики и технической поддержки оборудования."
      actions={[
        { label: "Оставить заявку", href: "/contacts", trackEvent: "support_lead" },
        { label: "Обсудить SLA", href: "/contacts", trackEvent: "support_sla" },
      ]}
    />

    <InnerPageSection
      eyebrow="Сервисные направления"
      title="Первая и вторая линии обслуживания + специализированные работы."
      cards={[
        {
          title: "First Line Maintenance",
          text: "Оперативные работы на первой линии: замена чековой ленты, сброс ошибок, первичная диагностика, снятие логов и базовая настройка ПО.",
          meta: "L1",
        },
        {
          title: "Second Line Maintenance",
          text: "Углубленная техническая поддержка: диагностика неисправностей, ремонт узлов и установка обновлений программного обеспечения.",
          meta: "L2",
        },
        {
          title: "Логистика и анкерение",
          text: "Организация перемещения оборудования, установка на площадке и подготовка к безопасной эксплуатации.",
          meta: "Field Service",
        },
        {
          title: "Ремонт кассет и модулей",
          text: "Проводим восстановление и обслуживание кассетных узлов для продления срока службы и снижения затрат на замену.",
          meta: "Repair",
        },
        {
          title: "Брендирование и кастомизация",
          text: "Адаптируем внешний вид устройств под бренд и требования площадки, включая элементы оформления и пользовательские зоны.",
          meta: "Branding",
        },
        {
          title: "Техническая поддержка ПО",
          text: "Сопровождаем настройку программной части, помогаем с диагностикой сбоев и поддерживаем стабильность сервисов на объектах.",
          meta: "Software",
        },
      ]}
    />
    <FinalStickyCta />
  </main>
</BaseLayout>
