---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";
import InnerPageHero from "../components/InnerPageHero.astro";
import InnerPageSection from "../components/InnerPageSection.astro";
import FinalStickyCta from "../components/FinalStickyCta.astro";
---

<BaseLayout
  title="Оборудование SAGA"
  description="Поставка комплектующих и оборудования для устройств самообслуживания с подбором под задачи бизнеса."
  footerVisible={true}
>
  <InnerPageHeader />
  <main class="snap-shell">
    <InnerPageHero
      eyebrow="Оборудование"
      title="Производство и поставка оборудования для систем самообслуживания."
      text="Собственное производство банкоматов, терминалов, касс самообслуживания и комплектующих. Дистрибуция компонентов для устройств самообслуживания и подбор конфигураций под задачи заказчика."
      actions={[
        { label: "Запросить подбор", href: "/#contacts", trackEvent: "equipment_lead" },
        { label: "Смотреть решения", href: "/solutions", trackEvent: "equipment_solutions" },
      ]}
    />

    <InnerPageSection
      eyebrow="Продуктовые линейки"
      title="Категории оборудования."
      cards={[
        { title: "Банкоматы", text: "Линейка банкоматов с экранами 19″, 27″ и 32″ для банковских отделений, зон 24/7 и инфраструктурных объектов.", meta: "ATM" },
        { title: "Автоматические депозитные машины", text: "ADM для автоматизации депозитных операций в кредитных организациях и коммерческих структурах.", meta: "ADM" },
        { title: "Кассы самообслуживания", text: "Решения для автоматизации кассовых операций в супермаркетах, гипермаркетах и торговых сетях.", meta: "КСО" },
        { title: "Системы управления очередью", text: "Терминалы электронной очереди различных форм-факторов для офисов обслуживания, МФЦ и банковских отделений.", meta: "СУО" },
        { title: "Информационные и платежные терминалы", text: "Инфокиоски и платежные терминалы для навигации, информирования и приема платежей в общественных пространствах.", meta: "Терминалы" },
        { title: "Зарядные станции", text: "Зарядная инфраструктура для электромобилей: станции для паркингов, коммерческих и городских объектов.", meta: "EV" },
      ]}
    />
    <FinalStickyCta />
  </main>
</BaseLayout>
