---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";
import InnerPageHero from "../components/InnerPageHero.astro";
import InnerPageSection from "../components/InnerPageSection.astro";
import FinalStickyCta from "../components/FinalStickyCta.astro";
---

<BaseLayout
  title="Оборудование SAGA"
  description="Поставка комплектующих и оборудования для устройств самообслуживания с подбором под задачи бизнеса."
  footerVisible={true}
>
  <InnerPageHeader />
  <main class="snap-shell">
    <InnerPageHero
      eyebrow="Оборудование"
      title="Комплектующие и оборудование для стабильной работы self-service."
      text="Поставляем комплектующие для устройств самообслуживания и помогаем собрать надежную конфигурацию под ваш сценарий: от пилота до масштабной сети."
      actions={[
        { label: "Запросить подбор", href: "/#contacts", trackEvent: "equipment_lead" },
        { label: "Смотреть решения", href: "/solutions", trackEvent: "equipment_solutions" },
      ]}
    />

    <InnerPageSection
      eyebrow="Продуктовые линейки"
      title="Что вы получаете при работе с нами."
      cards={[
        { title: "Подбор комплектующих под вашу задачу", text: "Анализируем модель оборудования, условия эксплуатации и бюджет, чтобы предложить оптимальный набор компонентов.", meta: "Подбор" },
        { title: "Поставка для новых и действующих сетей", text: "Закрываем потребность как для запуска новых устройств, так и для поддержки уже установленного парка.", meta: "Поставка" },
        { title: "Снижение простоев оборудования", text: "Помогаем выстроить запас критичных комплектующих, чтобы сократить время простоя и потери выручки.", meta: "Надежность" },
        { title: "Совместимость и консультации", text: "Проверяем совместимость и сопровождаем на этапе внедрения, чтобы исключить ошибки при установке.", meta: "Экспертиза" },
        { title: "Логистика и комплектация", text: "Организуем поставку и комплектацию под объекты, регионы и графики вашей сервисной команды.", meta: "Логистика" },
        { title: "Долгосрочное партнерство", text: "Работаем как технологический партнер, который помогает поддерживать стабильную работу оборудования в масштабе.", meta: "Партнерство" },
      ]}
    />
    <FinalStickyCta />
  </main>
</BaseLayout>
