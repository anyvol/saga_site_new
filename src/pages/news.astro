---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";
import InnerPageHero from "../components/InnerPageHero.astro";
import InnerPageSection from "../components/InnerPageSection.astro";
import FinalStickyCta from "../components/FinalStickyCta.astro";
---

<BaseLayout
  title="Новости SAGA"
  description="Ключевые события, важные мероприятия и достижения корпорации SAGA."
  footerVisible={true}
>
  <InnerPageHeader />
  <main class="snap-shell">
    <InnerPageHero
      eyebrow="Новости"
      title="События, мероприятия и достижения корпорации САГА."
      text="Основные этапы развития компании, участие в отраслевых выставках и конференциях, результаты проектов и новые направления деятельности."
      actions={[
        { label: "Связаться с нами", href: "/#contacts", trackEvent: "news_contact" },
        { label: "О компании", href: "/company" },
      ]}
    />

    <InnerPageSection
      eyebrow="События и достижения"
      title="Последние публикации"
      cards={[
        {
          title: "САГА — резидент ОЭЗ «Технополис Москва»",
          text: "Производственные мощности АО «САГА Технологии» размещены на площадке «Печатники» особой экономической зоны «Технополис Москва».",
          meta: "Производство",
        },
        {
          title: "Учебное оборудование для образовательных учреждений",
          text: "Корпорация САГА представила класс-комплект «Физика» и четырёхосевого учебного робота на профильных мероприятиях для частных школ.",
          meta: "Образование",
        },
        {
          title: "Платёжные терминалы на автоматических мойках",
          text: "Автоматические бесконтактные мойки LeisuWash по всей стране оснащены терминалами самообслуживания SAGA.",
          meta: "Внедрение",
        },
      ]}
    />
    <FinalStickyCta />
  </main>
</BaseLayout>
