---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";
import InnerPageHero from "../components/InnerPageHero.astro";
import InnerPageSection from "../components/InnerPageSection.astro";
import FinalStickyCta from "../components/FinalStickyCta.astro";
---

<BaseLayout
  title="Новости SAGA"
  description="Ключевые события, важные мероприятия и достижения корпорации SAGA."
  footerVisible={true}
>
  <InnerPageHeader />
  <main class="snap-shell">
    <InnerPageHero
      eyebrow="Новости"
      title="Ключевые события, мероприятия и достижения SAGA."
      text="Здесь публикуем важные этапы развития компании, участие в отраслевых мероприятиях и значимые результаты проектов. Ежедневные обновления и короткие новости ведем в наших социальных каналах."
      actions={[
        { label: "Связаться с нами", href: "/contacts", trackEvent: "news_contact" },
        { label: "О компании", href: "/company" },
      ]}
    />

    <InnerPageSection
      eyebrow="События и достижения"
      title="Важные публикации компании"
      cards={[
        {
          title: "Развитие производственных мощностей",
          text: "Расширяем производственную базу для ускорения запуска новых проектов и стабильных поставок оборудования.",
          meta: "Ключевое событие",
        },
        {
          title: "Участие в отраслевых мероприятиях",
          text: "Представляем решения SAGA на профильных площадках и делимся практикой внедрения с партнерами и заказчиками.",
          meta: "Мероприятия",
        },
        {
          title: "Новые проектные успехи",
          text: "Публикуем кейсы и результаты, которые подтверждают эффективность наших решений в реальной эксплуатации.",
          meta: "Достижения",
        },
      ]}
    />
    <FinalStickyCta />
  </main>
</BaseLayout>
