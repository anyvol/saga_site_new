---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";
import InnerPageHero from "../components/InnerPageHero.astro";
import InnerPageSection from "../components/InnerPageSection.astro";
import FinalStickyCta from "../components/FinalStickyCta.astro";
---

<BaseLayout
  title="Карьера в SAGA"
  description="Вакансии и карьерные возможности в команде SAGA."
  footerVisible={true}
>
  <InnerPageHeader />
  <main class="snap-shell">
    <InnerPageHero
      eyebrow="Карьера"
      title="Создаем инженерные и продуктовые решения вместе."
      text="Ищем специалистов в разработку, производство, сервис и продуктовые команды. Важны системное мышление, ответственность и желание строить масштабные решения."
      actions={[
        { label: "Отправить резюме", href: "mailto:hr@sagacorporation.com", trackEvent: "careers_cv" },
        { label: "О компании", href: "/company" },
      ]}
    />

    <InnerPageSection
      eyebrow="Почему SAGA"
      title="Среда для роста в промышленной high-tech компании."
      cards={[
        { title: "Реальные проекты", text: "Работа с продуктами, которые ежедневно используются в банках, ритейле и городской инфраструктуре." },
        { title: "Сильная инженерная культура", text: "Команды проектирования, производства и интеграции работают в едином контуре." },
        { title: "Долгосрочное развитие", text: "Прозрачные карьерные треки и участие в развитии новых направлений компании." },
      ]}
    />
    <FinalStickyCta />
  </main>
</BaseLayout>
