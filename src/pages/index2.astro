---
import BaseLayout from "../layouts/BaseLayout.astro";

const navItems = [
  { label: "Продукты", href: "#products" },
  { label: "Преимущества", href: "#advantages" },
  { label: "Отрасли", href: "#industries" },
  { label: "О компании", href: "#company" },
  { label: "Контакты", href: "#contacts" }
];

const products = [
  {
    key: "atm",
    title: "Банкоматы SAGA",
    text: "Российские банкоматы с современным дизайном и поддержкой рециркуляции наличных.",
    bullets: [
      "Экраны 19″, 27″ и 32″.",
      "Функция рециркуляции для оптимизации инкассации.",
      "Успешное прохождение испытаний Банка России.",
      "Включены в реестр российской промышленной продукции."
    ],
    image: "/assets/atms/saga_atm_27_front.jpg",
    booklet: "/assets/booklets/atm_booklet.pdf"
  },
  {
    key: "queue",
    title: "Системы управления очередью",
    text: "Комплексные решения для организации электронных очередей в офисах, МФЦ, банках и клиниках.",
    bullets: [
      "Гибкая настройка сценариев обслуживания и приоритетов.",
      "Понятный интерфейс для клиентов и персонала.",
      "Интеграция с информационными и платёжными сервисами.",
      "Статистика и аналитика по загруженности точек."
    ],
    image: "/assets/qms/syo_27_saga_front.jpg",
    booklet: "/assets/booklets/qms_booklet.pdf"
  },
  {
    key: "selfcheckout",
    title: "Кассы самообслуживания SAGA",
    text: "Линейка касс самообслуживания для розничной торговли и АЗС, сокращающая время обслуживания клиентов.",
    bullets: [
      "Поддержка различных сценариев оплаты и скидок.",
      "Интеграция с POS и учётными системами.",
      "Удобный интерфейс для покупателей и персонала.",
      "Увеличение пропускной способности торговых точек."
    ],
    image: "/assets/ssc/ssc_21_front_2.jpg",
    booklet: "/assets/booklets/ssc_booklet.pdf"
  }
];

const trustItems = [
  {
    value: "2006",
    label: "Год основания"
  },
  {
    value: "Full cycle",
    label: "Разработка, производство и сервис"
  },
  {
    value: "RU",
    label: "Собственная промышленная база в России"
  },
  {
    value: "B2B",
    label: "Решения для банков, ритейла и госсектора"
  }
];

const industries = [
  "Банки",
  "Ритейл",
  "МФЦ",
  "Клиники",
  "Транспорт",
  "Сервисные пространства"
];

const badges = [
  {
    name: "Резидент ОЭЗ",
    image: "/assets/logos/Rezident_TM.png"
  },
  {
    name: "Национальные чемпионы",
    image: "/assets/logos/national_champions.png"
  },
  {
    name: "Консорциум «Вычислительная техника»",
    image: "/assets/logos/logo_kvt.png"
  },
  {
    name: "Ассоциация НДО",
    image: "/assets/logos/logo-small_ando_v3.png"
  }
];

const contactIcons = [
  {
    label: "Позвонить",
    href: "tel:+78002222197",
    icon: "/assets/logos/телефон-logo.png"
  },
  {
    label: "Написать",
    href: "mailto:info@saga-tech.ru",
    icon: "/assets/logos/почта_logo.png"
  },
  {
    label: "Telegram",
    href: "https://t.me/SAGACorporation",
    icon: "/assets/logos/tg_logo.png"
  },
  {
    label: "MAX",
    href: "https://max.ru/id7718589473_biz",
    icon: "/assets/logos/Max_logo_2025.png"
  },
  {
    label: "VK",
    href: "https://vk.com/saga_tech",
    icon: "/assets/logos/VK Logo.png"
  }
];

const sections = [
  { id: "hero", label: "Hero" },
  { id: "products", label: "Продукты" },
  { id: "advantages", label: "Преимущества" },
  { id: "industries", label: "Отрасли" },
  { id: "company", label: "О компании" },
  { id: "contacts", label: "Контакты" }
];
---

<BaseLayout>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="#hero" aria-label="SAGA">
        <img src="/assets/logos/saga_logo_black.svg" alt="SAGA" class="brand-logo" />
      </a>

      <nav class="main-nav" aria-label="Основная навигация">
        {navItems.map((item) => (
          <a href={item.href} class="nav-link">{item.label}</a>
        ))}
      </nav>

      <a class="header-cta" href="#contacts">Связаться</a>

      <button class="menu-toggle" type="button" aria-label="Открыть меню">
        <span></span>
        <span></span>
      </button>
    </div>

    <div class="mobile-nav">
      <nav class="mobile-nav-inner" aria-label="Мобильная навигация">
        {navItems.map((item) => (
          <a href={item.href} class="mobile-nav-link">{item.label}</a>
        ))}
        <a href="#contacts" class="mobile-nav-link mobile-nav-link-accent">Связаться</a>
      </nav>
    </div>
  </header>

  <aside class="section-dots" aria-label="Навигация по экранам">
    {sections.map((section, index) => (
      <a
        href={`#${section.id}`}
        class={`section-dot ${index === 0 ? "is-active" : ""}`}
        data-dot={section.id}
        aria-label={section.label}
      ></a>
    ))}
  </aside>

  <main class="snap-shell" id="snap-shell">
    <section class="screen hero-screen" id="hero" data-section>
      <video
        class="hero-video"
        src="/assets/promo_atm.mp4"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>

      <div class="hero-overlay"></div>

      <div class="container hero-content">
        <div class="eyebrow reveal">Российские решения самообслуживания</div>
        <h1 class="hero-title reveal reveal-delay-1">
          Технологии, которые работают<br />
          в реальной инфраструктуре
        </h1>
        <p class="hero-text reveal reveal-delay-2">
          АО «САГА Технологии» разрабатывает и выпускает банкоматы, кассы
          самообслуживания и системы управления очередью для банков, ритейла,
          госсектора и сервисных пространств.
        </p>

        <div class="hero-actions reveal reveal-delay-3">
          <a href="#products" class="btn btn-primary">Смотреть решения</a>
          <a href="#contacts" class="btn btn-secondary">Связаться</a>
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="products" data-section>
      <div class="container panel-grid panel-grid-wide">
        <div class="section-copy reveal">
          <div class="eyebrow">Продукты</div>
          <h2>Три направления. Одна инженерная логика.</h2>
          <p>
            Мы показываем оборудование крупно, чисто и без визуального шума:
            сначала суть, потом детали, документы и сценарии применения.
          </p>
        </div>

        <div class="products-grid">
          {products.map((product, idx) => (
            <article class={`product-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
              <div class="product-media">
                <img src={product.image} alt={product.title} loading="lazy" />
              </div>

              <div class="product-body">
                <h3>{product.title}</h3>
                <p>{product.text}</p>

                <ul>
                  {product.bullets.map((bullet) => <li>{bullet}</li>)}
                </ul>

                <div class="product-actions">
                  <a class="text-link" href={product.booklet} target="_blank" rel="noopener">
                    Скачать PDF
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="advantages" data-section>
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Преимущества</div>
          <h2>Функция, надёжность и промышленная дисциплина.</h2>
          <p>
            Первый уровень доверия должен считываться за несколько секунд:
            опыт, производство, отрасли применения и зрелость решений.
          </p>
        </div>

        <div class="trust-layout">
          <div class="trust-stats">
            {trustItems.map((item, idx) => (
              <div class={`trust-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
                <div class="trust-value">{item.value}</div>
                <div class="trust-label">{item.label}</div>
              </div>
            ))}
          </div>

          <div class="badge-strip reveal reveal-delay-2">
            {badges.map((badge) => (
              <div class="badge-chip">
                <img src={badge.image} alt={badge.name} loading="lazy" />
                <span>{badge.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="industries" data-section>
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Отрасли</div>
          <h2>Решения для среды, где важны поток, надёжность и сервис.</h2>
          <p>
            Вместо длинных текстов — матрица сценариев. Пользователь сразу
            понимает, где и зачем применяется оборудование.
          </p>
        </div>

        <div class="industries-grid">
          {industries.map((item, idx) => (
            <div class={`industry-card reveal reveal-delay-${Math.min(idx % 3 + 1, 3)}`}>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="company" data-section>
      <div class="container company-layout">
        <div class="company-copy reveal">
          <div class="eyebrow">О компании</div>
          <h2>Собственная база. Полный цикл. Технологический фокус.</h2>
          <p>
            АО «САГА Технологии» основано в 2006 году. Мы сопровождаем весь
            цикл — от разработки и опытно-конструкторских работ до серийного
            производства и сервисной поддержки.
          </p>
          <p>
            Такой раздел можно позже вынести в отдельную страницу без полной
            переделки сайта: архитектура уже готова к росту.
          </p>

          <div class="hero-actions">
            <a href="#contacts" class="btn btn-primary">Обсудить проект</a>
          </div>
        </div>

        <div class="company-visual reveal reveal-delay-2">
          <img
            src="/assets/atms/saga_atm_32_front.jpg"
            alt="Банкомат SAGA"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <section class="screen panel-screen contact-screen" id="contacts" data-section>
      <div class="container contact-layout">
        <div class="section-copy reveal">
          <div class="eyebrow">Контакты</div>
          <h2>Связаться с нами</h2>
          <p>
            Удобный финальный экран без перегруза: быстрые действия, контакты и
            адреса, которые читаются за один взгляд.
          </p>
        </div>

        <div class="contact-card reveal reveal-delay-1">
          <div class="contact-group">
            <div class="contact-kicker">Телефоны</div>
            <a href="tel:+78002222197" class="contact-link">8 800 222-21-97</a>
            <a href="tel:+74959871121" class="contact-link">+7 495 987-11-21</a>
          </div>

          <div class="contact-group">
            <div class="contact-kicker">Почта</div>
            <a href="mailto:info@saga-tech.ru" class="contact-link">info@saga-tech.ru</a>
            <a href="mailto:press@sagacorporation.com" class="contact-link">
              press@sagacorporation.com
            </a>
          </div>

          <div class="contact-group">
            <div class="contact-kicker">Адреса</div>
            <div class="contact-text">Москва, Уральская, 21</div>
            <div class="contact-text">Москва, Волгоградский проспект, 42, к. 5</div>
            <div class="contact-text">Москва, Амурская, 9/6</div>
            <div class="contact-text">Москва, Монтажная, 2А, стр. 8</div>
          </div>

          <div class="contact-icons">
            {contactIcons.map((item) => (
              <a
                href={item.href}
                class="contact-icon"
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noopener" : undefined}
                aria-label={item.label}
              >
                <img src={item.icon} alt="" loading="lazy" />
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

    <script is:inline>
    const root = document.documentElement;
    const sections = Array.from(document.querySelectorAll("[data-section]"));
    const dots = Array.from(document.querySelectorAll("[data-dot]"));
    const menuToggle = document.querySelector(".menu-toggle");
    const header = document.querySelector(".site-header");
    const mobileLinks = Array.from(document.querySelectorAll(".mobile-nav-link"));
    const navLinks = Array.from(document.querySelectorAll('a[href^="#"]'));
    const revealEls = Array.from(document.querySelectorAll(".reveal"));

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    const setActiveSection = (id) => {
        dots.forEach((dot) => {
        dot.classList.toggle("is-active", dot.getAttribute("data-dot") === id);
        });
    };

    if (!prefersReducedMotion.matches) {
        root.classList.add("reveal-ready");

        const revealObserver = new IntersectionObserver(
        (entries, observer) => {
            entries.forEach((entry) => {
            if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
            }
            });
        },
        {
            threshold: 0.12
        }
        );

        revealEls.forEach((el) => revealObserver.observe(el));
    } else {
        revealEls.forEach((el) => el.classList.add("is-visible"));
    }

    const sectionObserver = new IntersectionObserver(
        (entries) => {
        const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

        if (visible?.target?.id) {
            setActiveSection(visible.target.id);
        }
        },
        {
        threshold: [0.35, 0.6, 0.85]
        }
    );

    sections.forEach((section) => sectionObserver.observe(section));

    const closeMenu = () => {
        header?.classList.remove("is-open");
    };

    if (menuToggle && header) {
        menuToggle.addEventListener("click", () => {
        header.classList.toggle("is-open");
        });
    }

    [...mobileLinks, ...navLinks].forEach((link) => {
        link.addEventListener("click", (e) => {
        const href = link.getAttribute("href");
        if (!href || !href.startsWith("#")) return;

        const target = document.querySelector(href);
        if (!target) return;

        e.preventDefault();
        closeMenu();
        target.scrollIntoView({ behavior: "smooth", block: "start" });
        });
    });

    if (prefersReducedMotion.matches) {
        document.querySelectorAll("video").forEach((video) => {
        video.removeAttribute("autoplay");
        });
    }
    </script>
</BaseLayout>
