---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";

const base = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${base.replace(/\/+$/, "")}/${path.replace(/^\/+/, "")}`;

const companyPillars = [
  {
    value: "Миссия",
    label: "Создаем надежные платформы самообслуживания, которые масштабируются под задачи заказчика.",
  },
  {
    value: "Производство",
    label: "Собственная инженерная и производственная база в России с контролем полного цикла.",
  },
  {
    value: "Сертификация",
    label: "Работаем в соответствии с требованиями отрасли и внутренними стандартами качества.",
  },
  {
    value: "Партнерство",
    label: "Сопровождаем проекты от пилота до сервисной эксплуатации на всей сети.",
  },
];

const companyIndustries = ["Банки", "Ритейл", "Госсектор", "Транспорт", "Инфраструктура", "EVC"];
---

<BaseLayout
  title="Компания — САГА Технологии"
  description="АО «САГА Технологии» — производство и сервисная поддержка решений самообслуживания."
  footerVisible={true}
>
  <InnerPageHeader />

  <main class="snap-shell">
    <section class="screen panel-screen" id="company">
      <div class="container company-layout">
        <div class="company-copy reveal">
          <div class="eyebrow">Компания</div>
          <h1 class="hero-title">От идеи до производства и сервисной поддержки.</h1>
          <p>
            АО «САГА Технологии» основано в 2006 году. Сайт теперь показывает не
            только отдельные продукты, но и целостный производственный контур —
            от разработки до серийного выпуска.
          </p>
          <p>
            Это создаёт правильный уровень доверия уже в первые минуты просмотра:
            виден продукт, видна вариативность линейки и видно, что за ней стоит
            реальное производство.
          </p>

          <div class="hero-actions">
            <a href={withBase("/contacts")} class="btn btn-primary" data-track-event="company_discuss_project">
              Обсудить проект
            </a>
            <a
              href="mailto:info@saga-tech.ru?subject=Запрос%20презентации%20о%20компании"
              class="btn btn-secondary"
              data-track-event="company_request_presentation"
            >
              Скачать презентацию
            </a>
          </div>
        </div>

        <div class="company-media-grid">
          <article class="company-media-card reveal reveal-delay-2">
            <video
              src={withBase("/assets/factory_saga_1.mp4")}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            ></video>
            <div class="feature-media-overlay">
              <div class="feature-kicker">Производство</div>
              <h3>Реальная производственная база</h3>
              <p>
                Видео с производства усиливает доверие к бренду и связывает
                продуктовую витрину с реальным производственным контуром.
              </p>
            </div>
          </article>

          <article class="company-media-card reveal reveal-delay-3">
            <video
              src={withBase("/assets/factory_saga_2.mp4")}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            ></video>
            <div class="feature-media-overlay">
              <div class="feature-kicker">Инженерия</div>
              <h3>Системная разработка и выпуск</h3>
              <p>
                Такой блок помогает коллегам и партнёрам быстро считать масштаб,
                зрелость и industrial feel компании.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="company-pillars">
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Ключевые блоки</div>
          <h2>Миссия, производство и партнерская модель.</h2>
          <p>
            Этот раздел помогает быстро считать, как устроена компания: зачем мы
            создаем решения, как обеспечиваем качество и как ведем долгосрочное
            сопровождение после запуска.
          </p>
        </div>

        <div class="trust-stats">
          {companyPillars.map((item, idx) => (
            <div class={`trust-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
              <div class="trust-value">{item.value}</div>
              <div class="trust-label">{item.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="company-industries">
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Отрасли</div>
          <h2>Работаем с проектами в ключевых сегментах.</h2>
          <p>
            Платформа решений легко адаптируется под сценарии обслуживания в
            разных отраслях: от банковских зон до инфраструктурных площадок.
          </p>
        </div>

        <div class="industries-grid">
          {companyIndustries.map((industry, idx) => (
            <article class={`industry-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
              <span>{industry}</span>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

</BaseLayout>

