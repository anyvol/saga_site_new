---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";
import { homeContactsHref } from "../utils/sitePaths";

const base = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${base.replace(/\/+$/, "")}/${path.replace(/^\/+/, "")}`;
const contactsHref = homeContactsHref();

const companyPillars = [
  {
    value: "С 2006 года",
    label: "АО «САГА Технологии» работает на рынке устройств самообслуживания и ИТ-решений более 15 лет.",
  },
  {
    value: "700+ моделей",
    label: "Производим банкоматы, ADM, платежные и информационные терминалы, кассы самообслуживания и другое оборудование.",
  },
  {
    value: "Полный цикл",
    label: "От проектирования и разработки до внедрения, запуска и сервисной поддержки на стороне заказчика.",
  },
  {
    value: "Собственное производство",
    label: "Площадки в Москве и Московской области, оснащенные современным оборудованием для работы с металлом и пластиком.",
  },
];

const companyIndustries = [
  "Банки и финтех",
  "Ритейл и торговля",
  "Транспортная инфраструктура",
  "Государственный сектор",
  "Образование",
  "Промышленные проекты",
];
---

<BaseLayout
  title="Компания — САГА Технологии"
  description="АО «САГА Технологии» — российский производитель оборудования и ИТ-решений в области систем самообслуживания."
  footerVisible={true}
>
  <InnerPageHeader />

  <main class="snap-shell">
    <section class="screen panel-screen" id="company">
      <div class="container company-layout">
        <div class="company-copy reveal">
          <div class="eyebrow">Компания</div>
          <h1 class="hero-title">Российский производитель оборудования и ИТ-решений.</h1>
          <p>
            Акционерное общество «САГА Технологии» основано 9 июня 2006 года.
            Головной офис расположен в Москве. Компания разрабатывает и
            производит высокотехнологичное оборудование и программно-аппаратные
            решения для систем самообслуживания.
          </p>
          <p>
            Мы создаем решения полного цикла: от анализа задач заказчика и
            проектирования до производства, внедрения и дальнейшей эксплуатации.
            Такой подход позволяет быстро запускать проекты и масштабировать их
            без потери качества.
          </p>

          <div class="hero-actions">
            <a href={contactsHref} class="btn btn-primary" data-track-event="company_discuss_project">
              Обсудить проект
            </a>
            <a
              href="mailto:info@saga-tech.ru?subject=Запрос%20презентации%20о%20компании"
              class="btn btn-secondary"
              data-track-event="company_request_presentation"
            >
              Запросить презентацию
            </a>
          </div>
        </div>

        <div class="company-media-grid">
          <article class="company-media-card reveal reveal-delay-2">
            <video
              src={withBase("/assets/factory_saga_1.mp4")}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            ></video>
            <div class="feature-media-overlay">
              <div class="feature-kicker">Производство</div>
              <h3>Собственная производственная база</h3>
              <p>
                Площадки в Москве и Московской области оснащены современным
                парком станков для работы со сталью, алюминием и пластиком.
              </p>
            </div>
          </article>

          <article class="company-media-card reveal reveal-delay-3">
            <video
              src={withBase("/assets/factory_saga_2.mp4")}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
            ></video>
            <div class="feature-media-overlay">
              <div class="feature-kicker">Инженерия</div>
              <h3>Сильная инженерная команда</h3>
              <p>
                В компании работают инженеры, конструкторы, программисты,
                технологи и аналитики, которые решают сложные и нестандартные
                задачи в короткие сроки.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="company-pillars">
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Ключевые блоки</div>
          <h2>Почему нам доверяют крупные проекты.</h2>
          <p>
            На протяжении многих лет SAGA Technologies остается заметным игроком
            в сегменте банковского и финтех-оборудования в России и странах СНГ,
            развивая собственные продукты и сервисную экспертизу.
          </p>
        </div>

        <div class="trust-stats">
          {companyPillars.map((item, idx) => (
            <div class={`trust-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
              <div class="trust-value">{item.value}</div>
              <div class="trust-label">{item.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="screen panel-screen" id="company-industries">
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Отрасли</div>
          <h2>Ключевые направления развития.</h2>
          <p>
            Помимо базового направления самообслуживания, развиваем проекты в
            области робототехники, образовательных и инфраструктурных решений в
            рамках политики импортозамещения.
          </p>
        </div>

        <div class="industries-grid">
          {companyIndustries.map((industry, idx) => (
            <article class={`industry-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
              <span>{industry}</span>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

</BaseLayout>

