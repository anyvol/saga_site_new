---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";
import InnerPageHero from "../components/InnerPageHero.astro";
import InnerPageSection from "../components/InnerPageSection.astro";
import FinalStickyCta from "../components/FinalStickyCta.astro";
---

<BaseLayout
  title="Решения SAGA"
  description="Решения SAGA для банков, ритейла и инфраструктуры: закрываем бизнес-проблемы с помощью оборудования и ПО."
  footerVisible={true}
>
  <InnerPageHeader />
  <main class="snap-shell">
    <InnerPageHero
      eyebrow="Решения"
      title="Комплексные решения для автоматизации обслуживания и операций с наличностью."
      text="Проектирование и внедрение программно-аппаратных решений на базе собственного оборудования: автоматизация инкассации, валютообменные пункты, электронная очередь, кассы самообслуживания и платежные системы."
      actions={[
        { label: "Обсудить проект", href: "/#contacts", trackEvent: "solutions_discuss" },
        { label: "Смотреть оборудование", href: "/equipment", trackEvent: "solutions_equipment" },
      ]}
    />

    <InnerPageSection
      eyebrow="Ключевые направления"
      title="Направления деятельности."
      lead="Каждое решение включает полный цикл: от разработки технического задания и проектирования до внедрения и запуска в промышленную эксплуатацию."
      cards={[
        {
          title: "Автоматизация инкассации",
          text: "Оптимизация себестоимости инкассации в кредитных организациях с использованием автоматических депозитных машин и специализированного ПО.",
          meta: "Финансовый сектор",
        },
        {
          title: "Электронная очередь и самообслуживание",
          text: "Программно-аппаратные комплексы для управления клиентским потоком, кассы самообслуживания и информационные терминалы для банковских и сервисных учреждений.",
          meta: "Клиентский сервис",
        },
        {
          title: "Транспортные и инфраструктурные решения",
          text: "Автоматизация оплаты на платных трассах, парковочных комплексах и муниципальных парковках. Билетные решения для транспортных объектов.",
          meta: "Инфраструктура",
        },
      ]}
    />

    <InnerPageSection
      id="impact"
      eyebrow="Эффект внедрения"
      title="Результат внедрения."
      cards={[
        {
          title: "Снижение операционных издержек",
          text: "Автоматизация операций с наличностью и обслуживания клиентов сокращает стоимость владения инфраструктурой.",
        },
        {
          title: "Повышение качества обслуживания",
          text: "Управление потоком клиентов, сокращение времени ожидания и предоставление каналов самообслуживания.",
        },
        {
          title: "Масштабируемость решений",
          text: "Единая программная платформа управления устройствами позволяет расширять сеть без полной переработки процессов.",
        },
      ]}
    />

    <FinalStickyCta />
  </main>
</BaseLayout>
