---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";
import InnerPageHero from "../components/InnerPageHero.astro";
import InnerPageSection from "../components/InnerPageSection.astro";
import FinalStickyCta from "../components/FinalStickyCta.astro";
---

<BaseLayout
  title="Решения SAGA"
  description="Решения SAGA для банков, ритейла и инфраструктуры: закрываем бизнес-проблемы с помощью оборудования и ПО."
  footerVisible={true}
>
  <InnerPageHeader />
  <main class="snap-shell">
    <InnerPageHero
      eyebrow="Решения"
      title="Решения, которые устраняют узкие места в клиентском сервисе и операциях."
      text="Проектируем и внедряем решения на базе собственного оборудования и ПО: от приема платежей и управления очередью до автоматизации операций с наличностью."
      actions={[
        { label: "Обсудить проект", href: "/#contacts", trackEvent: "solutions_discuss" },
        { label: "Смотреть оборудование", href: "/equipment", trackEvent: "solutions_equipment" },
      ]}
    />

    <InnerPageSection
      eyebrow="Ключевые направления"
      title="Какие проблемы бизнеса мы решаем."
      lead="Каждое решение строится вокруг конкретной задачи заказчика: сократить очереди, ускорить обслуживание, снизить издержки и повысить надежность инфраструктуры."
      cards={[
        {
          title: "Долгое обслуживание и очереди",
          text: "Внедряем электронную очередь, инфокиоски и кассы самообслуживания, чтобы распределить поток клиентов и сократить время ожидания.",
          meta: "Клиентский сервис",
        },
        {
          title: "Высокие затраты на работу с наличностью",
          text: "Автоматизируем процессы с использованием ADM и платежного оборудования, повышая прозрачность операций и снижая операционные расходы.",
          meta: "Финтех",
        },
        {
          title: "Разрозненная инфраструктура точек",
          text: "Объединяем оборудование и программные компоненты в единый контур управления, чтобы упростить масштабирование и контроль сети.",
          meta: "Единая платформа",
        },
      ]}
    />

    <InnerPageSection
      id="impact"
      eyebrow="Эффект внедрения"
      title="Какой результат получает заказчик."
      cards={[
        {
          title: "Снижение операционных издержек",
          text: "Автоматизация рутинных операций и продуманная сервисная модель сокращают стоимость владения инфраструктурой.",
        },
        {
          title: "Рост скорости обслуживания",
          text: "Клиенты быстрее проходят типовые сценарии, а сотрудники высвобождают время для задач с большей ценностью.",
        },
        {
          title: "Надежная масштабируемость",
          text: "Решения легко расширяются на новые точки и регионы без полной переработки архитектуры и процессов.",
        },
      ]}
    />

    <FinalStickyCta />
  </main>
</BaseLayout>
