---
import BaseLayout from "../../layouts/BaseLayout.astro";
import InnerPageHeader from "../../components/InnerPageHeader.astro";
import { homeContactsHref } from "../../utils/sitePaths";
import { deviceSections } from "../../data/categories";
import { getProductsByCategory, loadAllProducts, type Product } from "../../data/products";
import ImageLightboxIsland from "../../components/ImageLightboxIsland.jsx";
import { Image } from "astro:assets";

const base = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${base.replace(/\/+$/, "")}/${path.replace(/^\/+/, "")}`;
const contactsHref = homeContactsHref();
const resolveImageHref = (href?: string | null) => {
  if (!href) return "";
  if (/^(?:https?:)?\/\//.test(href) || href.startsWith("data:") || href.startsWith("blob:")) {
    return href;
  }
  const normalizedBase = base.replace(/\/+$/, "");
  if (normalizedBase && (href === normalizedBase || href.startsWith(`${normalizedBase}/`))) {
    return href;
  }
  return href.startsWith("/") ? withBase(href) : withBase(`/${href}`);
};

const resolveBookletHref = (href?: string | null) => {
  if (!href) return null;
  // В JSON иногда хранится абсолютный путь к ассету без base.
  if (href.startsWith("/assets/")) return withBase(href);
  return href;
};

export async function getStaticPaths() {
  const allProducts = loadAllProducts();
  const categoryIds = Array.from(
    new Set([
      ...deviceSections.map((section) => section.id),
      ...allProducts.map((p) => p.categoryId),
    ])
  );

  return categoryIds.map((categoryId) => ({
    params: { categoryId },
  }));
}

const { categoryId } = Astro.params;
const products = getProductsByCategory(String(categoryId));
const section = deviceSections.find((s) => s.id === categoryId);

const lineEyebrow = section?.eyebrow ?? "Линейка";
const lineTitle = section?.title ?? String(categoryId);
const lineIntro = section?.intro ?? "";
const lineSeoDescription = `${lineTitle} — ${lineIntro || "Подбор конфигураций, характеристики и консультация по внедрению."}`;

const lineContentMap: Record<
  string,
  {
    usp: string[];
    scenarios: string[];
    faq: { q: string; a: string }[];
  }
> = {
  atm: {
    usp: [
      "Единый продуктовый язык SAGA для банковских и инфраструктурных сценариев.",
      "Широкий выбор диагоналей для разных форматов отделений и зон 24/7.",
      "Готовность к масштабированию пилота до сетевого внедрения.",
    ],
    scenarios: ["Банковские отделения", "Зоны 24/7", "Транспортные узлы"],
    faq: [
      {
        q: "Можно ли подобрать конфигурацию под ограниченное пространство?",
        a: "Да, линейка включает компактные варианты и флагманские модели для разных условий размещения.",
      },
      {
        q: "Есть ли материалы для проектной презентации?",
        a: "Да, для категории доступны карточки моделей, характеристики и PDF-материалы.",
      },
    ],
  },
  qms: {
    usp: [
      "Гибкие форм-факторы СУО для разных клиентских потоков.",
      "Понятный UX-паттерн выбора устройств внутри одной категории.",
      "Современная визуальная подача для сервисных пространств.",
    ],
    scenarios: ["Офисы обслуживания", "МФЦ", "Розничные сервисные зоны"],
    faq: [
      {
        q: "Подходит ли линейка для высоконагруженных площадок?",
        a: "Да, в линейке есть крупные конфигурации с высокой визуальной заметностью.",
      },
      {
        q: "Можно ли сравнить форм-факторы перед выбором?",
        a: "Да, внутри страницы доступны карточки моделей и их характеристики для сравнения.",
      },
    ],
  },
  ssc: {
    usp: [
      "Конфигурации касс самообслуживания под разные розничные сценарии.",
      "Единая подача моделей для быстрого сравнения и выбора.",
      "Адаптивность к требованиям конкретной торговой точки.",
    ],
    scenarios: ["Супермаркеты", "DIY и электроника", "Форматы self-checkout"],
    faq: [
      {
        q: "Чем отличаются конфигурации внутри линейки?",
        a: "Отличаются компоновкой пользовательской зоны и периферии под конкретный сценарий внедрения.",
      },
      {
        q: "Есть ли поддержка пилотного запуска?",
        a: "Да, можно начать с одной конфигурации и масштабировать решение на сеть.",
      },
    ],
  },
  adm: {
    usp: [
      "Самостоятельная категория для депозитных сценариев.",
      "Набор визуальных материалов для уверенной продуктовой презентации.",
      "Единый UX внутри каталога без смены логики навигации.",
    ],
    scenarios: ["Банковские отделения", "Премиальные зоны", "Проектные внедрения"],
    faq: [
      {
        q: "Можно ли использовать страницу ADM как отдельный продуктовый лендинг?",
        a: "Да, страница уже содержит структуру для переговорной демонстрации и расширяется дополнительными блоками.",
      },
      {
        q: "Где смотреть характеристики?",
        a: "Техническая информация доступна в карточках моделей в блоке характеристик.",
      },
    ],
  },
  info: {
    usp: [
      "Инфокиоски и платежные терминалы в едином продуктовым каркасе сайта.",
      "Быстрое расширение линейки без изменения шаблона страницы.",
      "Понятная структура для внутренних и внешних презентаций.",
    ],
    scenarios: ["Корпоративные холлы", "Госучреждения", "Навигационные сервисы"],
    faq: [
      {
        q: "Можно ли расширить линейку новыми моделями?",
        a: "Да, новые модели добавляются в каталог и автоматически появляются на странице линейки.",
      },
      {
        q: "Есть ли материалы для согласования проекта?",
        a: "Да, карточки, характеристики и консультация по запросу доступны на странице.",
      },
    ],
  },
  charging: {
    usp: [
      "Отдельное направление для EV-инфраструктуры внутри общей платформы решений.",
      "Понятное позиционирование для коммерческих и инфраструктурных проектов.",
      "Быстрый переход от ознакомления к запросу консультации.",
    ],
    scenarios: ["Паркинги и ТРЦ", "Корпоративные площадки", "Городская инфраструктура"],
    faq: [
      {
        q: "Подходит ли линейка для масштабирования сети?",
        a: "Да, архитектура раздела предусматривает добавление новых моделей и сценариев.",
      },
      {
        q: "Как обсудить подбор станции под объект?",
        a: "Нажмите кнопку связи на странице категории и отправьте параметры проекта.",
      },
    ],
  },
};

const lineContent = lineContentMap[String(categoryId)] ?? {
  usp: [
    "Понятная структура линейки с быстрым переходом к нужной модели.",
    "Единая подача характеристик и сценариев применения.",
  ],
  scenarios: ["Проектные внедрения", "Коммерческие объекты"],
  faq: [
    {
      q: "Как подобрать конфигурацию?",
      a: "Оставьте заявку через контакты, и команда подберет вариант под ваш сценарий.",
    },
  ],
};

---

<BaseLayout
  title={`${lineTitle} — САГА Технологии`}
  description={lineSeoDescription}
  footerVisible={true}
>
  <InnerPageHeader />

  <main class="snap-shell">
    <section class="screen panel-screen line-screen-hero">
      <div class="container">
        <div class="line-hero-wrap">
          <div class="line-hero-copy">
            <div class="eyebrow">{lineEyebrow}</div>
            <h1 class="hero-title line-hero-title">{lineTitle}</h1>
            <p class="hero-text line-hero-text">{lineIntro}</p>

            <div class="hero-actions" style="margin-top: 18px;">
              <a href={withBase("/company")} class="btn btn-secondary">
                О компании
              </a>
              <a
                href={contactsHref}
                class="btn btn-primary"
                data-open-lead-modal
                data-track-event="line_discuss_project"
              >
                Обсудить проект
              </a>
            </div>
          </div>

          <div class="line-hero-bg" aria-hidden="true" />
        </div>
      </div>
    </section>

    <section class="screen panel-screen line-screen-products">
      <div class="container">
        <div class="products-grid" aria-label={`Продукты линейки: ${lineTitle}`}>
          {products.map((product) => {
            const startIndex = product.images.findIndex((img) => img.isPrimary);
            const lightboxStartIndex = startIndex >= 0 ? startIndex : 0;
            const lightboxSrcs = product.images.map((img) => resolveImageHref(img.src));
            const lightboxAlts = product.images.map((img) => img.alt || product.title);
            const bookletHref = resolveBookletHref(
              product.sectionBooklet ?? section?.sectionBooklet
            );

            const primaryImage = product.images.find((img) => img.isPrimary) ?? product.images[0];
            const primaryAlt = primaryImage?.alt || product.title;

            return (
              <article class="product-card">
                <button
                  type="button"
                  class="product-media product-media-trigger"
                  data-open-lightbox
                  data-lightbox-srcs={JSON.stringify(lightboxSrcs)}
                  data-lightbox-alts={JSON.stringify(lightboxAlts)}
                  data-lightbox-start-index={lightboxStartIndex}
                  aria-label={`Открыть изображения: ${product.title}`}
                >
                  {primaryImage?.optimized ? (
                    <Image
                      src={primaryImage.optimized}
                      alt={primaryAlt}
                      loading="lazy"
                    />
                  ) : (
                    <img
                      src={primaryImage ? resolveImageHref(primaryImage.src) : ""}
                      alt={primaryAlt}
                      loading="lazy"
                    />
                  )}
                </button>

                <div class="product-body">
                  <h3>{product.title}</h3>
                  <p>{product.intro}</p>

                  {product.bullets?.length ? (
                    <ul>
                      {product.bullets.map((b) => (
                        <li>{b}</li>
                      ))}
                    </ul>
                  ) : null}

                  {product.specs && Object.keys(product.specs).length ? (
                    <div class="product-specs">
                      <div class="product-specs-title">Техническая информация</div>
                      <dl class="product-specs-dl">
                        {Object.entries(product.specs).map(([key, value]) => (
                          <div class="product-specs-row">
                            <dt class="product-specs-key">{key}</dt>
                            <dd class="product-specs-value">
                              {Array.isArray(value) ? value.join(", ") : String(value)}
                            </dd>
                          </div>
                        ))}
                      </dl>
                    </div>
                  ) : null}

                  <div class="product-actions device-action-row">
                    {bookletHref ? (
                      <a
                        class="btn btn-ghost btn-pdf"
                        href={bookletHref}
                        target="_blank"
                        rel="noopener"
                        data-track-event="line_download_pdf"
                      >
                        <svg class="btn-pdf-icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                          <path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm-1 2 5 5h-5V4zM8 13h2.5a1.5 1.5 0 0 1 0 3H8v-3zm4 0h2v2h-2v-2zm0-2a2 2 0 0 1 2-2h1v-2h-4v4h1z"/>
                        </svg>
                        PDF
                      </a>
                    ) : null}

                    <a
                      class="btn btn-ghost btn-pdf"
                      href={contactsHref}
                      data-open-lead-modal
                      aria-label="Перейти к контактам"
                      data-track-event="line_to_contacts"
                    >
                      <img
                        class="btn-phone-icon"
                        src={withBase("/assets/logos/телефон-logo.png")}
                        alt=""
                        loading="lazy"
                        width="18"
                        height="18"
                      />
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="screen panel-screen">
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Преимущества линейки</div>
          <h2>Почему выбирают {lineEyebrow.toLowerCase()} SAGA.</h2>
          <p>
            В этом разделе собраны ключевые причины выбора категории: от
            инженерной зрелости до удобства масштабирования в рамках сети.
          </p>
        </div>

        <div class="trust-stats">
          {lineContent.usp.map((item, idx) => (
            <article class={`trust-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
              <div class="trust-value">0{idx + 1}</div>
              <div class="trust-label">{item}</div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="screen panel-screen">
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">Сценарии</div>
          <h2>Где применяют решения категории.</h2>
          <p>
            Типовые сценарии помогают быстрее понять, в каких пространствах и
            процессах категория дает наибольшую ценность.
          </p>
        </div>

        <div class="industries-grid">
          {lineContent.scenarios.map((scenario, idx) => (
            <article class={`industry-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
              <span>{scenario}</span>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="screen panel-screen">
      <div class="container panel-grid">
        <div class="section-copy reveal">
          <div class="eyebrow">FAQ</div>
          <h2>Частые вопросы по категории.</h2>
          <p>
            Короткие ответы для этапа первичного выбора. Для детальной
            спецификации можно перейти к контакту с командой.
          </p>
        </div>

        <div class="trust-stats">
          {lineContent.faq.map((item, idx) => (
            <article class={`trust-card reveal reveal-delay-${Math.min(idx + 1, 3)}`}>
              <div class="contact-kicker">{item.q}</div>
              <p>{item.a}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <ImageLightboxIsland client:load />
</BaseLayout>

