---
import BaseLayout from "../layouts/BaseLayout.astro";
import InnerPageHeader from "../components/InnerPageHeader.astro";
import InnerPageHero from "../components/InnerPageHero.astro";
import InnerPageSection from "../components/InnerPageSection.astro";
import FinalStickyCta from "../components/FinalStickyCta.astro";
---

<BaseLayout
  title="Пресса о SAGA"
  description="Материалы для СМИ и публикации о проектах SAGA."
  footerVisible={true}
>
  <InnerPageHeader />
  <main class="snap-shell">
    <InnerPageHero
      eyebrow="Пресса"
      title="Материалы для медиа и партнерских публикаций."
      text="Раздел для журналистов и PR-команд: краткие анонсы, инфоповоды и контакты пресс-службы для оперативной коммуникации."
      actions={[
        { label: "Написать в пресс-службу", href: "mailto:press@sagacorporation.com", trackEvent: "press_mail" },
        { label: "Новости", href: "/news" },
      ]}
    />

    <InnerPageSection
      eyebrow="Публикации"
      title="Темы для освещения"
      cards={[
        { title: "Технологические разработки", text: "Новые решения в области самообслуживания, инженерии и цифровой инфраструктуры.", meta: "Media Brief" },
        { title: "Партнерства и проекты", text: "Совместные инициативы с банками, ритейлом и государственными структурами.", meta: "Case Story" },
        { title: "Производственный контур", text: "Материалы о производстве, масштабировании и контроле качества.", meta: "Industry Insight" },
      ]}
    />
    <FinalStickyCta />
  </main>
</BaseLayout>
