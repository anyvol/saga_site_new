---
interface CardItem {
  title: string;
  text: string;
  meta?: string;
}

interface Props {
  id?: string;
  eyebrow: string;
  title: string;
  lead?: string;
  cards?: CardItem[];
}

const { id, eyebrow, title, lead, cards = [] } = Astro.props;
---

<section class="screen panel-screen inner-screen" id={id}>
  <div class="container panel-grid">
    <div class="section-copy reveal">
      <div class="eyebrow">{eyebrow}</div>
      <h2>{title}</h2>
      {lead && <p>{lead}</p>}
    </div>

    {cards.length > 0 && (
      <div class="info-cards">
        {cards.map((card, index) => (
          <article class={`info-card reveal reveal-delay-${Math.min(index + 1, 3)}`}>
            {card.meta && <div class="info-card-meta">{card.meta}</div>}
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
