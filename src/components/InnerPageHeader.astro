---
import { homeContactsHref } from "../utils/sitePaths";

const contactsHref = homeContactsHref();
const navLinks = [
  { label: "Главная", href: "/" },
  { label: "Решения", href: "/solutions" },
  { label: "Оборудование", href: "/equipment" },
  { label: "Поддержка", href: "/support" },
  { label: "Новости", href: "/news" },
  { label: "Контакты", href: contactsHref },
];
const base = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${base.replace(/\/+$/, "")}/${path.replace(/^\/+/, "")}`;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={withBase("/")} aria-label="SAGA">
      <img
        src={`${import.meta.env.BASE_URL.replace(/\/+$/, "")}/assets/logos/saga_logo_black.svg`}
        alt="SAGA"
        class="brand-logo"
      />
    </a>

    <nav class="main-nav" aria-label="Основная навигация">
      {navLinks.map((item) => (
        <a
          href={item.href.includes("#") ? item.href : withBase(item.href)}
          class="nav-link"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button class="menu-toggle" type="button" aria-label="Открыть меню">
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="mobile-nav">
    <nav class="mobile-nav-inner" aria-label="Мобильная навигация">
      {navLinks.map((item) => (
        <a
          href={item.href.includes("#") ? item.href : withBase(item.href)}
          class="mobile-nav-link"
        >
          {item.label}
        </a>
      ))}
      <a href={contactsHref} class="mobile-nav-link mobile-nav-link-accent">Оставить заявку</a>
    </nav>
  </div>
</header>

<script is:inline>
  const header = document.querySelector(".site-header");
  const menuToggle = document.querySelector(".menu-toggle");
  const mobileLinks = Array.from(document.querySelectorAll(".mobile-nav-link"));
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  const closeMenu = () => header?.classList.remove("is-open");
  menuToggle?.addEventListener("click", () => header?.classList.toggle("is-open"));
  mobileLinks.forEach((link) => link.addEventListener("click", closeMenu));
  window.addEventListener("scroll", closeMenu, { passive: true });

  const initReveals = () => {
    const root = document.documentElement;
    const revealEls = Array.from(document.querySelectorAll(".reveal"));
    if (!prefersReducedMotion.matches) {
      root.classList.add("reveal-ready");
      const scrollRoot = document.querySelector(".snap-shell");
      const getRootHeight = () =>
        scrollRoot instanceof HTMLElement ? scrollRoot.clientHeight : window.innerHeight;
      const isInRevealViewport = (el) => {
        const rect = el.getBoundingClientRect();
        const viewportHeight = getRootHeight();
        return rect.bottom > 0 && rect.top < viewportHeight * 0.95;
      };
      revealEls.forEach((el) => {
        if (!isInRevealViewport(el)) return;
        el.classList.add("is-visible");
      });
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          });
        },
        { threshold: 0.12, root: scrollRoot instanceof Element ? scrollRoot : null }
      );
      revealEls
        .filter((el) => !el.classList.contains("is-visible"))
        .forEach((el) => revealObserver.observe(el));
    } else {
      revealEls.forEach((el) => el.classList.add("is-visible"));
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initReveals, { once: true });
  } else {
    initReveals();
  }
</script>
