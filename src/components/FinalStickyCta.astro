---
import { homeContactsHref } from "../utils/sitePaths";

interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Готовы обсудить ваш проект?",
  text = "Подберем конфигурацию под ваш сценарий и сроки внедрения.",
} = Astro.props;

const contactsHref = homeContactsHref();
---

<section class="screen panel-screen final-sticky-screen">
  <div class="container">
    <div class="final-sticky-cta reveal">
      <div class="final-sticky-copy">
        <div class="eyebrow">CTA</div>
        <h2>{title}</h2>
        <p>{text}</p>
      </div>
      <div class="hero-actions">
        <a href={contactsHref} class="btn btn-primary" data-track-event="final_cta_contact">
          Оставить заявку
        </a>
        <a href="tel:+78002222197" class="btn btn-ghost" data-track-event="final_cta_call">
          Позвонить
        </a>
      </div>
    </div>
  </div>
</section>
