---
interface Props {
  version?: string;
  isVisible?: boolean;
}

const { version = "0.143", isVisible = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const withBase = (path: string) =>
  `${base.replace(/\/+$/, "")}/${path.replace(/^\/+/, "")}`;
const links = [
  { label: "Решения", href: "/solutions", external: false },
  { label: "Оборудование", href: "/equipment", external: false },
  { label: "Поддержка", href: "/support", external: false },
  { label: "Новости", href: "/news", external: false },
  {
    label: "Карьера",
    href: "https://hh.ru/employer/3289751?hhtmFrom=vacancy",
    external: true,
  },
];
---

<footer class:list={["site-footer", isVisible && "is-visible"]} id="site-footer" data-footer>
  <div class="container site-footer-inner">
    <span class="site-footer-left">АО «САГА Технологии», 2026</span>
    <nav class="site-footer-links" aria-label="Разделы сайта">
      {links.map((link) => (
        <a
          href={link.external ? link.href : withBase(link.href)}
          class="site-footer-link"
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noopener noreferrer" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <span class="site-footer-right">Версия сайта: {version}</span>
  </div>
</footer>
